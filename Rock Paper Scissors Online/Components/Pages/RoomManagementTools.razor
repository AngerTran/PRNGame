@page "/tools/room-management"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth

<PageTitle>Room management</PageTitle>

<div class="rps-community-shell rps-tools-page">
    <header class="rps-community-hero">
        <p class="rps-community-kicker"><i class="bi bi-sliders" aria-hidden="true"></i> Vận hành · Phòng</p>
        <h1 class="rps-community-title">Room management API</h1>
        <p class="text-muted small mb-0">
            <span class="rps-community-api-label">[Authorize]</span>
            Thống kê, dọn phòng, truy vấn trạng thái và thao tác quản trị.
        </p>
    </header>
    <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
        <a class="rps-hub-pill" href="/portal"><i class="bi bi-cpu" aria-hidden="true"></i>Trung tâm</a>
        <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
    </nav>

    @if (_session == null)
    {
        <div class="card rps-tools-guest border-secondary">
            <div class="card-body text-center">
                <p class="text-muted small mb-3 mb-md-0">Đăng nhập với tài khoản có quyền để gọi API quản lý phòng.</p>
                <a class="btn btn-primary btn-sm" href="/login">Đăng nhập</a>
            </div>
        </div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                Thao tác nhanh
            </div>
            <div class="card-body">
                <div class="rps-community-toolbar rps-mgmt-quick flex-wrap align-items-center">
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="@(() => Go(() => Api.RoomMgmtStatsAsync()))">
                        <i class="bi bi-graph-up" aria-hidden="true"></i>stats
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="@(() => Go(() => Api.RoomMgmtCleanupInactiveAsync()))">
                        <i class="bi bi-trash" aria-hidden="true"></i>cleanup inactive
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="@(() => Go(() => Api.RoomMgmtLowActivityAsync(_min)))">
                        <i class="bi bi-hourglass-split" aria-hidden="true"></i>low-activity
                    </button>
                    <span class="text-muted small ms-1 me-1 d-none d-sm-inline">·</span>
                    <label class="small text-muted fw-semibold mb-0 me-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.06em;" for="rps-rm-min">Ngưỡng</label>
                    <input id="rps-rm-min" type="number" class="form-control form-control-sm" @bind="_min" />
                    <span class="small text-muted">phút (low-activity)</span>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-search" aria-hidden="true"></i>
                Truy vấn
            </div>
            <div class="card-body pt-3">
                <p class="rps-mgmt-section-title">Theo trạng thái / người tạo</p>
                <div class="rps-mgmt-row">
                    <span class="rps-mgmt-row-label">by-status</span>
                    <input class="form-control form-control-sm" @bind="_status" placeholder="Waiting, Playing, Finished…" autocomplete="off" />
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => Go(() => Api.RoomMgmtByStatusAsync(_status)))">GET</button>
                </div>
                <div class="rps-mgmt-row">
                    <span class="rps-mgmt-row-label">by-creator</span>
                    <input class="form-control form-control-sm" @bind="_creator" placeholder="creatorId" autocomplete="off" />
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => Go(() => Api.RoomMgmtByCreatorAsync(_creator)))">GET</button>
                </div>
                <div class="rps-mgmt-row">
                    <span class="rps-mgmt-row-label">room health</span>
                    <input class="form-control form-control-sm" @bind="_roomId2" placeholder="roomId" autocomplete="off" />
                    <button type="button" class="btn btn-sm btn-outline-info" @onclick="@(() => Go(() => Api.RoomMgmtRoomHealthAsync(_roomId2)))">GET</button>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-exclamation-octagon" aria-hidden="true"></i>
                Thao tác ghi (POST)
            </div>
            <div class="card-body pt-3">
                <div class="rps-mgmt-row">
                    <span class="rps-mgmt-row-label">force-close</span>
                    <input class="form-control form-control-sm" @bind="_roomId" placeholder="roomId" autocomplete="off" />
                    <input class="form-control form-control-sm" @bind="_reason" placeholder="reason" autocomplete="off" />
                    <button type="button" class="btn btn-sm btn-warning" @onclick="@(() => Go(() => Api.RoomMgmtForceCloseAsync(_roomId, _reason)))">POST</button>
                </div>
                <div class="rps-mgmt-row">
                    <span class="rps-mgmt-row-label">transfer</span>
                    <input class="form-control form-control-sm" @bind="_roomId3" placeholder="roomId" autocomplete="off" />
                    <input class="form-control form-control-sm" @bind="_toUser" placeholder="toUserId" autocomplete="off" />
                    <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => Go(() => Api.RoomMgmtTransferOwnershipAsync(_roomId3, _toUser)))">POST</button>
                </div>
            </div>
        </div>

        <JsonApiResult Json="@_j" Error="@_e" />
    }
</div>

@code {
    private PortalAuthState? _session;
    private int _min = 30;
    private string _status = "Waiting";
    private string _creator = "";
    private string _roomId = "";
    private string _reason = "admin";
    private string _roomId2 = "";
    private string _roomId3 = "";
    private string _toUser = "";
    private string? _j, _e;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        StateHasChanged();
    }

    private async Task Go(Func<Task<(bool Ok, string Body, string? Error)>> fn)
    {
        _e = null; _j = null;
        var (ok, body, err) = await fn();
        _j = ok ? body : null;
        _e = err;
    }
}
