@page "/register"
@layout AuthLayout
@rendermode InteractiveServer
@inject GameApiService Api
@inject NavigationManager Nav

<PageTitle>Đăng ký</PageTitle>

<div class="rps-auth-page">
    <AuthBrandSide Subtitle="Tạo tài khoản miễn phí, chơi realtime qua SignalR." />
    <div class="rps-form-narrow rps-auth-panel">
        <header class="rps-auth-panel-head">
            <h1 class="h2 mb-0">Đăng ký</h1>
            <p class="text-muted mb-0">Tạo tài khoản để vào sảnh và chơi.</p>
        </header>

        <EditForm Model="_dto" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            <div class="rps-auth-fields">
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    <InputText class="form-control" @bind-Value="_dto.Username" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_dto.Email" autocomplete="email" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <InputText type="password" class="form-control" @bind-Value="_dto.Password" autocomplete="new-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tên hiển thị (tuỳ chọn)</label>
                    <InputText class="form-control" @bind-Value="_dto.DisplayName" autocomplete="nickname" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger" role="alert">@_error</div>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <div class="alert alert-success" role="alert">@_success</div>
            }
            <button class="btn btn-primary" type="submit" disabled="@_busy">@(_busy ? "Đang gửi…" : "Đăng ký")</button>
        </EditForm>
        <p class="mt-4 mb-0 small rps-auth-footer-links">
            <a href="/login">Đã có tài khoản? Đăng nhập</a>
            <span class="rps-auth-footer-sep" aria-hidden="true">·</span>
            <a href="/lobby">Sảnh</a>
        </p>
    </div>
</div>

@code {
    private readonly RegisterDto _dto = new();
    private string? _error;
    private string? _success;
    private bool _busy;

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var (ok, err) = await Api.RegisterAsync(_dto);
            if (!ok)
            {
                _error = err ?? "Đăng ký thất bại";
                return;
            }

            _success = "Đăng ký thành công. Chuyển tới đăng nhập…";
            await Task.Delay(600);
            Nav.NavigateTo("/login", forceLoad: false);
        }
        catch (HttpRequestException)
        {
            _error = "Không kết nối được máy chủ. Vui lòng thử lại sau ít giây.";
        }
        catch (TaskCanceledException)
        {
            _error = "Yêu cầu bị timeout. Vui lòng thử lại.";
        }
        catch (Exception)
        {
            _error = "Có lỗi không mong muốn khi đăng ký. Vui lòng thử lại.";
        }
        finally
        {
            _busy = false;
        }
    }
}
