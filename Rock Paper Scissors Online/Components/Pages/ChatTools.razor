@page "/tools/chat"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth

<PageTitle>Chat API</PageTitle>

<div class="rps-community-shell rps-tools-page">
    <header class="rps-community-hero">
        <p class="rps-community-kicker"><i class="bi bi-chat-dots" aria-hidden="true"></i> REST · Chat</p>
        <h1 class="rps-community-title">Chat &amp; activity</h1>
        <p class="text-muted small mb-0">Tin nhắn global, feed hoạt động và chat theo phòng — gọi API thủ công để thử.</p>
    </header>
    <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
        <a class="rps-hub-pill" href="/portal"><i class="bi bi-cpu" aria-hidden="true"></i>Trung tâm</a>
        <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
    </nav>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item"><button type="button" class="nav-link @A(0)" @onclick='()=>_t=0'>Global GET</button></li>
        <li class="nav-item"><button type="button" class="nav-link @A(1)" @onclick='()=>_t=1'>Global POST</button></li>
        <li class="nav-item"><button type="button" class="nav-link @A(2)" @onclick='()=>_t=2'>Activity feed</button></li>
        <li class="nav-item"><button type="button" class="nav-link @A(3)" @onclick='()=>_t=3'>Room chat</button></li>
    </ul>

    <div class="rps-chat-tab-panel">
        @if (_t == 0)
        {
            <div class="rps-community-toolbar">
                <button type="button" class="btn btn-sm btn-primary" @onclick="GlobGetAsync">
                    <i class="bi bi-download" aria-hidden="true"></i>GET global messages
                </button>
            </div>
            <p class="rps-history-api-hint mb-3">
                <i class="bi bi-link-45deg" aria-hidden="true"></i>
                <span>Global chat — đọc tin nhắn công khai (giới hạn 80).</span>
            </p>
            <JsonApiResult Json="@_j" Error="@_e" />
        }
        @if (_t == 1)
        {
            @if (_session == null)
            {
                <div class="card rps-tools-guest border-secondary">
                    <div class="card-body text-center">
                        <p class="text-muted small mb-3 mb-md-0">Đăng nhập để gửi tin global (cần UserId).</p>
                        <a class="btn btn-primary btn-sm" href="/login">Đăng nhập</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <i class="bi bi-send-fill" aria-hidden="true"></i>
                        Gửi tin nhắn global
                    </div>
                    <div class="card-body">
                        <label class="rps-tools-field-label" for="rps-chat-global-msg">Nội dung (tối đa 100 ký tự)</label>
                        <div class="input-group" style="max-width: min(32rem, 100%);">
                            <input id="rps-chat-global-msg" class="form-control" @bind="_msg" maxlength="100" autocomplete="off" />
                            <button type="button" class="btn btn-primary" @onclick="GlobPostAsync">
                                <i class="bi bi-send" aria-hidden="true"></i>Gửi
                            </button>
                        </div>
                    </div>
                </div>
                <JsonApiResult Json="@_j" Error="@_e" />
            }
        }
        @if (_t == 2)
        {
            <div class="rps-community-toolbar">
                <button type="button" class="btn btn-sm btn-primary" @onclick="FeedAsync">
                    <i class="bi bi-activity" aria-hidden="true"></i>GET activity-feed
                </button>
            </div>
            <p class="rps-history-api-hint mb-3">
                <i class="bi bi-link-45deg" aria-hidden="true"></i>
                <span>Feed hoạt động — 25 mục gần nhất.</span>
            </p>
            <JsonApiResult Json="@_j" Error="@_e" />
        }
        @if (_t == 3)
        {
            @if (_session == null)
            {
                <div class="card rps-tools-guest border-secondary">
                    <div class="card-body text-center">
                        <p class="text-muted small mb-3 mb-md-0">Chat phòng yêu cầu đăng nhập <span class="rps-community-api-label d-inline">[Authorize]</span></p>
                        <a class="btn btn-primary btn-sm" href="/login">Đăng nhập</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <i class="bi bi-door-closed" aria-hidden="true"></i>
                        Chat theo phòng
                    </div>
                    <div class="card-body">
                        <label class="rps-tools-field-label" for="rps-chat-room">roomId</label>
                        <input id="rps-chat-room" class="form-control mb-3" style="max-width: min(24rem, 100%);" @bind="_roomId" placeholder="roomId" autocomplete="off" />
                        <div class="rps-community-toolbar mb-3">
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="RoomGetAsync">
                                <i class="bi bi-chat-left-text" aria-hidden="true"></i>GET messages
                            </button>
                        </div>
                        <label class="rps-tools-field-label" for="rps-chat-room-msg">Gửi vào phòng</label>
                        <div class="input-group" style="max-width: min(32rem, 100%);">
                            <input id="rps-chat-room-msg" class="form-control" @bind="_rmsg" maxlength="100" autocomplete="off" />
                            <button type="button" class="btn btn-primary" @onclick="RoomPostAsync">POST</button>
                        </div>
                    </div>
                </div>
                <JsonApiResult Json="@_j" Error="@_e" />
            }
        }
    </div>
</div>

@code {
    private int _t;
    private PortalAuthState? _session;
    private string? _j, _e;
    private string _msg = "Hello!";
    private string _roomId = "";
    private string _rmsg = "Hi room";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        StateHasChanged();
    }

    private string A(int x) => _t == x ? "active" : "";

    private async Task GlobGetAsync()
    {
        _e = null; _j = null;
        var (ok, body, err) = await Api.GetGlobalChatMessagesAsync(80);
        _j = ok ? body : null; _e = err;
    }

    private async Task GlobPostAsync()
    {
        _e = null; _j = null;
        var (ok, body, err) = await Api.SendGlobalChatAsync(_msg);
        _j = ok ? body : null; _e = err;
    }

    private async Task FeedAsync()
    {
        _e = null; _j = null;
        var (ok, body, err) = await Api.GetActivityFeedAsync(25);
        _j = ok ? body : null; _e = err;
    }

    private async Task RoomGetAsync()
    {
        _e = null; _j = null;
        var (ok, body, err) = await Api.GetRoomChatMessagesAsync(_roomId, 80);
        _j = ok ? body : null; _e = err;
    }

    private async Task RoomPostAsync()
    {
        _e = null; _j = null;
        var (ok, body, err) = await Api.SendRoomChatAsync(_roomId, _rmsg);
        _j = ok ? body : null; _e = err;
    }
}
