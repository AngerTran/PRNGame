@page "/tools/rooms"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager Nav

<PageTitle>API phòng</PageTitle>

<div class="rps-community-shell rps-tools-page">
    <header class="rps-community-hero">
        <p class="rps-community-kicker"><i class="bi bi-hdd-network" aria-hidden="true"></i> REST · Phòng</p>
        <h1 class="rps-community-title">Rooms API</h1>
        <p class="text-muted small mb-0">Tham gia bằng PIN, spectator, rời phòng, xoá phòng và xem chi tiết qua API.</p>
    </header>
    <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
        <a class="rps-hub-pill" href="/portal"><i class="bi bi-cpu" aria-hidden="true"></i>Trung tâm</a>
        <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
    </nav>

    @if (_session == null)
    {
        <div class="card rps-tools-guest border-secondary">
            <div class="card-body text-center">
                <p class="text-muted small mb-3 mb-md-0">Đăng nhập để gọi API phòng với token của bạn.</p>
                <a class="btn btn-primary btn-sm" href="/login">Đăng nhập</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 align-items-stretch">
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-key-fill" aria-hidden="true"></i>
                        Join by PIN
                    </div>
                    <div class="card-body">
                        <label class="rps-tools-field-label" for="rps-room-pin">Mã PIN</label>
                        <input id="rps-room-pin" class="form-control mb-3" @bind="_pin" placeholder="PIN" autocomplete="off" />
                        <button type="button" class="btn btn-primary btn-sm" @onclick="JoinPinAsync">
                            <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>POST join-by-pin
                        </button>
                        <JsonApiResult Json="@_j1" Error="@_e1" />
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                        Spectator / Leave / Delete
                    </div>
                    <div class="card-body">
                        <label class="rps-tools-field-label" for="rps-room-id">roomId</label>
                        <input id="rps-room-id" class="form-control mb-2" @bind="_roomId" placeholder="roomId" autocomplete="off" />
                        <label class="rps-tools-field-label" for="rps-room-pin2">PIN (tuỳ chọn spectator)</label>
                        <input id="rps-room-pin2" class="form-control mb-3" @bind="_pin2" placeholder="PIN (tuỳ chọn spectator)" autocomplete="off" />
                        <div class="rps-tools-btn-grid">
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="SpecAsync">
                                <i class="bi bi-binoculars" aria-hidden="true"></i>join-as-spectator
                            </button>
                            <button type="button" class="btn btn-outline-warning btn-sm" @onclick="LeaveAsync">
                                <i class="bi bi-door-open" aria-hidden="true"></i>leave
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="DelAsync">
                                <i class="bi bi-trash3" aria-hidden="true"></i>delete
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DetailsAsync">
                                <i class="bi bi-info-circle" aria-hidden="true"></i>GET details
                            </button>
                        </div>
                        <JsonApiResult Json="@_j2" Error="@_e2" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private PortalAuthState? _session;
    private string _pin = "";
    private string _roomId = "";
    private string _pin2 = "";
    private string? _j1, _e1, _j2, _e2;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        StateHasChanged();
    }

    private async Task JoinPinAsync()
    {
        _e1 = null; _j1 = null;
        var (ok, room, err) = await Api.JoinRoomByPinAsync(_pin.Trim());
        _j1 = ok && room != null ? System.Text.Json.JsonSerializer.Serialize(room) : null;
        _e1 = err;
    }

    private async Task SpecAsync()
    {
        _e2 = null; _j2 = null;
        var (ok, body, err) = await Api.JoinAsSpectatorAsync(_roomId, string.IsNullOrWhiteSpace(_pin2) ? null : _pin2);
        _j2 = ok ? body : null; _e2 = err;
    }

    private async Task LeaveAsync()
    {
        _e2 = null; _j2 = null;
        var (ok, body, err) = await Api.LeaveRoomAsync(_roomId);
        _j2 = ok ? body : null; _e2 = err;
    }

    private async Task DelAsync()
    {
        _e2 = null; _j2 = null;
        var (ok, body, err) = await Api.DeleteRoomAsync(_roomId);
        _j2 = ok ? body : null; _e2 = err;
    }

    private async Task DetailsAsync()
    {
        _e2 = null; _j2 = null;
        var (ok, body, err) = await Api.GetRoomDetailsRawAsync(_roomId);
        _j2 = ok ? body : null; _e2 = err;
    }
}
