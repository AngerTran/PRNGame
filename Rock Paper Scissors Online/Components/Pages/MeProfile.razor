@page "/me"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager Nav

<PageTitle>Hồ sơ</PageTitle>

@if (!_ready)
{
    <p>Đang tải…</p>
}
else if (_session == null)
{
    <p><a href="/login">Đăng nhập</a></p>
}
else
{
    <h1 class="h3">Hồ sơ (Profile API)</h1>
    <p class="small"><a href="/portal">← Trung tâm</a></p>

    <ul class="nav nav-tabs mb-3 flex-wrap">
        <li class="nav-item"><button type="button" class="nav-link @C(0)" @onclick='() => _t=0'>Tổng quan (tôi)</button></li>
        <li class="nav-item"><button type="button" class="nav-link @C(3)" @onclick='() => _t=3'>Hồ sơ người khác</button></li>
        <li class="nav-item"><button type="button" class="nav-link @C(1)" @onclick='() => _t=1'>GET .../stats (raw)</button></li>
        <li class="nav-item"><button type="button" class="nav-link @C(2)" @onclick='() => _t=2'>GET .../history</button></li>
    </ul>

    @if (_t == 0 && _profile != null)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h5">@_profile.User.Username</h2>
                <p class="small text-muted mb-1">@_profile.User.Email</p>
                <p>Điểm: @_profile.User.Points · Trận: @_profile.Stats.GamesPlayed (thắng @_profile.Stats.GamesWon)</p>
            </div>
        </div>
    }

    @if (_t == 1)
    {
        <button type="button" class="btn btn-sm btn-primary mb-2" @onclick="LoadStatsRawAsync">Tải api/v1/profile/@(_session.UserId)/stats</button>
        <JsonApiResult Json="@_statsRaw" Error="@_statsErr" />
    }

    @if (_t == 2)
    {
        <button type="button" class="btn btn-sm btn-primary mb-2" @onclick="LoadHistoryAsync">Tải history</button>
        <ul class="list-group small">
            @foreach (var g in _hist?.RecentGames ?? new List<GameHistoryDto>())
            {
                <li class="list-group-item">@g.Opponent — @g.Result · @(g.PointsEarned >= 0 ? "+" : "")@g.PointsEarned điểm · @g.Timestamp.ToLocalTime():g</li>
            }
        </ul>
        <JsonApiResult Json="@_histRaw" Error="@_histErr" />
    }

    @if (_t == 3)
    {
        <p class="small text-muted">Gọi <code>GET api/v1/profile/&#123;userId&#125;</code> với GUID người chơi khác.</p>
        <div class="input-group mb-3" style="max-width:32rem">
            <input class="form-control" @bind="_otherGuid" placeholder="Guid người chơi" />
            <button type="button" class="btn btn-primary" @onclick="LoadOtherProfileAsync">Tải hồ sơ</button>
        </div>
        @if (!string.IsNullOrEmpty(_otherErr))
        {
            <div class="alert alert-danger py-2 small">@_otherErr</div>
        }
        @if (_otherProfile != null)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h5">@_otherProfile.User.Username</h2>
                    <p class="small text-muted mb-1">@_otherProfile.User.Email</p>
                    <p class="mb-0">Điểm: @_otherProfile.User.Points · Trận: @_otherProfile.Stats.GamesPlayed (thắng @_otherProfile.Stats.GamesWon)</p>
                </div>
            </div>
            <p class="small text-muted mb-0">Lịch sử trận qua <code>GET .../history</code> chỉ cho tài khoản của bạn (bảo mật). Xem hồ sơ công khai ở tab trên.</p>
        }
    }
}

@code {
    private bool _ready;
    private int _t;
    private PortalAuthState? _session;
    private CompleteProfileDto? _profile;
    private string? _statsRaw;
    private string? _statsErr;
    private GameHistoryResponseDto? _hist;
    private string? _histRaw;
    private string? _histErr;
    private string _otherGuid = "";
    private CompleteProfileDto? _otherProfile;
    private string? _otherErr;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        if (_session == null)
        {
            _ready = true;
            StateHasChanged();
            return;
        }
        var (ok, p, _) = await Api.GetCompleteProfileAsync(_session.UserId);
        _profile = p;
        _ready = true;
        StateHasChanged();
    }

    private string C(int x) => _t == x ? "active" : "";

    private async Task LoadStatsRawAsync()
    {
        if (_session == null) return;
        _statsErr = null;
        var (ok, body, err) = await Api.GetProfileStatsRawAsync(_session.UserId);
        _statsRaw = ok ? body : null;
        _statsErr = err;
    }

    private async Task LoadHistoryAsync()
    {
        if (_session == null) return;
        _histErr = null;
        _histRaw = null;
        var (ok, h, err) = await Api.GetProfileHistoryAsync(_session.UserId, 30, 0);
        _hist = h;
        if (!ok) _histErr = err;
        if (ok && h != null)
            _histRaw = System.Text.Json.JsonSerializer.Serialize(h, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    private async Task LoadOtherProfileAsync()
    {
        _otherErr = null;
        _otherProfile = null;
        if (!Guid.TryParse(_otherGuid.Trim(), out var gid))
        {
            _otherErr = "GUID không hợp lệ.";
            return;
        }
        var (ok, p, err) = await Api.GetCompleteProfileAsync(gid);
        if (!ok || p == null)
        {
            _otherErr = err ?? "Không tìm thấy người chơi.";
            return;
        }
        _otherProfile = p;
    }

}
