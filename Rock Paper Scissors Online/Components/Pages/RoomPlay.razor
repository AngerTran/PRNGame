@page "/play/{RoomId}"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@using System.Text.Json
@using System.Threading
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager Nav

<PageTitle>Phòng @RoomId</PageTitle>

@if (!_ready)
{
    <div class="rps-play-skel px-1" aria-busy="true">
        <div class="rps-lobby-skeleton-line rps-lobby-skeleton-line--lg"></div>
        <div class="rps-lobby-skeleton-card" style="height:12rem"></div>
    </div>
}
else
{
    <div class="rps-play-shell">
        <div class="rps-play">
            <header class="rps-play-head">
                <div>
                    <p class="rps-lobby-kicker mb-1">Phòng đấu</p>
                    <h1 class="rps-play-title">@(_room?.Name ?? "Phòng")</h1>
                    @if (_showRoundInfo)
                    {
                        <p class="rps-play-current-round mb-0">Round hiện tại: <strong>@CurrentRoundDisplay</strong></p>
                    }
                </div>
                <a class="rps-play-leave" href="/lobby"><i class="bi bi-box-arrow-left" aria-hidden="true"></i> Rời / Sảnh</a>
            </header>

            @if (_isCreator && _room?.IsPrivate == true && !string.IsNullOrWhiteSpace(_room.PinCode))
            {
                <div class="rps-play-pin-banner" role="status">
                    <i class="bi bi-key-fill me-2" aria-hidden="true"></i>
                    <span>Phòng riêng — mã PIN (chỉ bạn thấy): <strong class="rps-play-pin-code">@_room.PinCode</strong></span>
                    <span class="rps-play-pin-banner-sub">Gửi mã này cho người chơi kia; họ nhập trong hộp thoại khi bấm Vào phòng ở sảnh.</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(_hubError))
            {
                <div class="alert alert-danger rps-play-alert py-2">@_hubError</div>
            }
            @if (!string.IsNullOrEmpty(_toast))
            {
                <div class="alert alert-info rps-play-alert py-2 small mb-3">@_toast</div>
            }

            <div class="row g-3">
                <div class="col-lg-4">
                    <section class="rps-play-panel">
                        <div class="rps-play-panel-h">Trạng thái</div>
                        <div class="rps-play-panel-b">
                            @if (_room != null)
                            {
                                <dl class="mb-0">
                                    <div class="rps-play-stat">
                                        <dt>Giai đoạn</dt>
                                        <dd>@_phase</dd>
                                    </div>
                                    <div class="rps-play-stat">
                                        <dt>Bạn</dt>
                                        <dd>@_session!.Username</dd>
                                    </div>
                                    <div class="rps-play-stat">
                                        <dt>Chủ phòng</dt>
                                        <dd>@_room.CreatedByUsername</dd>
                                    </div>
                                    <div class="rps-play-stat">
                                        <dt>Điểm</dt>
                                        <dd>P1 @ScoreP1 — P2 @ScoreP2</dd>
                                    </div>
                                    <div class="rps-play-stat">
                                        <dt>Hiệp đã chơi / tối đa</dt>
                                        <dd>@_room.CurrentRound / @_room.BestOfRounds</dd>
                                    </div>
                                    @if (DisplayCountdownSeconds is int pickRemain && pickRemain > 0)
                                    {
                                        <div class="rps-play-stat">
                                            <dt>@DisplayCountdownLabel</dt>
                                            <dd class="rps-play-pick-remaining">@pickRemain giây</dd>
                                        </div>
                                    }
                                    <div class="rps-play-stat">
                                        <dt>Thưởng nếu thắng trận</dt>
                                        <dd>@_room.PointsPerWin xu (một lần khi kết thúc)</dd>
                                    </div>
                                    <div class="rps-play-stat">
                                        <dt>Người chơi 1</dt>
                                        <dd>
                                            @if (_room.Player1 == null)
                                            {
                                                <text>—</text>
                                            }
                                            else
                                            {
                                                @_room.Player1.Username
                                                @if (_room.Player1.IsReady)
                                                {
                                                    <span class="rps-play-ready-ic"> ✓</span>
                                                }
                                            }
                                        </dd>
                                    </div>
                                    <div class="rps-play-stat">
                                        <dt>Người chơi 2</dt>
                                        <dd>
                                            @if (_room.Player2 == null)
                                            {
                                                <text>—</text>
                                            }
                                            else
                                            {
                                                @_room.Player2.Username
                                                @if (_room.Player2.IsReady)
                                                {
                                                    <span class="rps-play-ready-ic"> ✓</span>
                                                }
                                            }
                                        </dd>
                                    </div>
                                </dl>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">Không có dữ liệu phòng.</p>
                            }
                        </div>
                    </section>
                </div>
                <div class="col-lg-4">
                    <section class="rps-play-panel">
                        <div class="rps-play-panel-h">Hành động</div>
                        <div class="rps-play-panel-b">
                            <div class="rps-play-actions">
                                @if (AmIReady)
                                {
                                    <button class="btn rps-play-btn-unready" type="button" disabled="@_hubBusy" @onclick="() => SetReadyAsync(false)">
                                        <i class="bi bi-x-lg me-1" aria-hidden="true"></i>Hủy sẵn sàng
                                    </button>
                                }
                                else
                                {
                                    <button class="btn rps-play-btn-ready" type="button" disabled="@_hubBusy" @onclick="() => SetReadyAsync(true)">
                                        <i class="bi bi-check2-circle me-1" aria-hidden="true"></i>Sẵn sàng
                                    </button>
                                }
                                @if (_isCreator)
                                {
                                    <button class="btn rps-play-btn-start" type="button" disabled="@_hubBusy" @onclick="StartGameAsync">
                                        <i class="bi bi-play-fill me-1" aria-hidden="true"></i>Bắt đầu game
                                    </button>
                                }
                            </div>
                            @if (DisplayCountdownSeconds is int pickActionLeft && pickActionLeft > 0)
                            {
                                <div class="rps-play-turn-timer" role="status">
                                    <span class="rps-play-turn-timer-label">@DisplayCountdownLabel</span>
                                    <strong class="rps-play-turn-timer-seconds">@pickActionLeft</strong>
                                    <span class="rps-play-turn-timer-unit">giây</span>
                                </div>
                            }
                        </div>
                    </section>
                </div>
                <div class="col-lg-4">
                    <section class="rps-play-panel">
                        <div class="rps-play-panel-h">Kết quả từng ván</div>
                        <div class="rps-play-panel-b">
                            @if (_roundHistory.Count == 0)
                            {
                                <p class="text-muted small mb-0">Chưa có kết quả ván nào.</p>
                            }
                            else
                            {
                                <ol class="rps-play-round-list">
                                    @foreach (var line in _roundHistory)
                                    {
                                        <li>@line</li>
                                    }
                                </ol>
                            }
                        </div>
                    </section>
                </div>
            </div>

            <section class="rps-play-moves">
                <div class="rps-play-moves-h">Nước đi · búa · bao · kéo</div>
                <div class="rps-play-moves-b">
                    <button class="@MoveButtonClass("rock")" type="button" disabled="@_hubBusy"
                        aria-label="Chọn búa đá (rock)" @onclick='() => MoveAsync("rock")'>
                        <img class="rps-play-move-img" src="rps-moves/rock.svg" width="80" height="80" decoding="async" alt="" />
                        <span class="rps-play-move-label">Búa đá</span>
                    </button>
                    <button class="@MoveButtonClass("paper")" type="button" disabled="@_hubBusy"
                        aria-label="Chọn bao (paper)" @onclick='() => MoveAsync("paper")'>
                        <img class="rps-play-move-img" src="rps-moves/paper.svg" width="80" height="80" decoding="async" alt="" />
                        <span class="rps-play-move-label">Bao</span>
                    </button>
                    <button class="@MoveButtonClass("scissors")" type="button" disabled="@_hubBusy"
                        aria-label="Chọn kéo (scissors)" @onclick='() => MoveAsync("scissors")'>
                        <img class="rps-play-move-img" src="rps-moves/scissors.svg" width="80" height="80" decoding="async" alt="" />
                        <span class="rps-play-move-label">Kéo</span>
                    </button>
                </div>
            </section>

            <RpsDualChatPanel RoomGameHub="_hub" GameRoomId="@RoomId" />

            @if (_winnerPanelVisible)
            {
                <div class="rps-play-winner-overlay" role="dialog" aria-modal="true" aria-labelledby="rps-winner-title">
                    <div class="rps-play-winner-card">
                        <p id="rps-winner-title" class="rps-play-winner-kicker">Trận đấu đã kết thúc</p>
                        <p class="rps-play-winner-label">Người chiến thắng</p>
                        <p class="rps-play-winner-name"><i class="bi bi-trophy-fill rps-play-winner-ic" aria-hidden="true"></i>@_gameWinnerDisplay</p>
                        <button class="btn rps-play-winner-dismiss" type="button" @onclick="DismissWinnerPanel">Đóng</button>
                    </div>
                </div>
            }

            @if (_revealVisible)
            {
                <div class="rps-play-reveal-overlay" role="dialog" aria-modal="true" aria-labelledby="rps-reveal-title">
                    <div class="rps-play-reveal-card">
                        <p id="rps-reveal-title" class="rps-play-reveal-kicker">Cả hai đã chọn</p>
                        @if (!_revealMovesVisible)
                        {
                            <p class="rps-play-reveal-count" aria-live="polite">@RevealSecondsLeft</p>
                            <p class="rps-play-reveal-count-label">giây tới lúc mở bài</p>
                        }
                        else
                        {
                            <p class="rps-play-reveal-opened">Mở bài</p>
                        }
                        <div class="rps-play-reveal-vs">
                            <div class="rps-play-reveal-side">
                                <span class="rps-play-reveal-name">@_revealP1Username</span>
                                @if (_revealMovesVisible)
                                {
                                    <img class="rps-play-reveal-img" src="@MoveSvgSrc(_revealP1Move)" width="96" height="96" decoding="async" alt="" />
                                }
                                else
                                {
                                    <div class="rps-play-reveal-placeholder" aria-hidden="true">?</div>
                                }
                            </div>
                            <span class="rps-play-reveal-vs-txt">vs</span>
                            <div class="rps-play-reveal-side">
                                <span class="rps-play-reveal-name">@_revealP2Username</span>
                                @if (_revealMovesVisible)
                                {
                                    <img class="rps-play-reveal-img" src="@MoveSvgSrc(_revealP2Move)" width="96" height="96" decoding="async" alt="" />
                                }
                                else
                                {
                                    <div class="rps-play-reveal-placeholder" aria-hidden="true">?</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string RoomId { get; set; } = "";

    [SupplyParameterFromQuery] public string? Pin { get; set; }

    private PortalAuthState? _session;
    private RoomResponseDto? _room;
    private HubConnection? _hub;
    private bool _ready;
    private bool _hubBusy;
    private bool _isCreator;
    private string _phase = "—";
    private string? _hubError;
    private string? _toast;
    private string? _lastRound;
    private readonly List<string> _roundHistory = new();
    private bool _winnerPanelVisible;
    private string _gameWinnerDisplay = "";
    private bool _showRoundInfo;

    private bool _revealVisible;
    private string? _revealP1Move;
    private string? _revealP2Move;
    private string _revealP1Username = "";
    private string _revealP2Username = "";
    private DateTime _revealEndsAtUtc;
    private CancellationTokenSource? _revealTickerCts;
    private bool _revealMovesVisible;
    private int? _phaseSecondsLeft;
    private string? _selectedMove;

    private int RevealSecondsLeft =>
        !_revealVisible ? 0 : Math.Max(0, (int)Math.Ceiling((_revealEndsAtUtc - DateTime.UtcNow).TotalSeconds));

    private int? DisplayCountdownSeconds => IsCountdownPhase(_phase) ? _phaseSecondsLeft : null;

    private string DisplayCountdownLabel => _phase.ToLowerInvariant() switch
    {
        "betting_phase" => "Chuẩn bị ván mới",
        "battle_start" => "Bắt đầu ra tay",
        "round_active" => "Chọn nước đi",
        _ => "Đếm ngược"
    };

    private int ScoreP1 => _room?.PlayerScores?.GetValueOrDefault(_room.Player1?.UserId ?? "", 0) ?? 0;
    private int ScoreP2 => _room?.PlayerScores?.GetValueOrDefault(_room.Player2?.UserId ?? "", 0) ?? 0;
    private string CurrentRoundDisplay
    {
        get
        {
            var max = _room?.BestOfRounds ?? 0;
            var cur = _room?.CurrentRound ?? 0;
            if (max <= 0)
                return "1/1";
            var shown = cur <= 0 ? 1 : cur;
            if (shown > max)
                shown = max;
            return $"{shown}/{max}";
        }
    }

    private bool AmIReady
    {
        get
        {
            if (_session == null || _room == null)
                return false;
            var uid = _session.UserId.ToString();
            if (string.Equals(_room.Player1?.UserId, uid, StringComparison.OrdinalIgnoreCase))
                return _room.Player1?.IsReady ?? false;
            if (string.Equals(_room.Player2?.UserId, uid, StringComparison.OrdinalIgnoreCase))
                return _room.Player2?.IsReady ?? false;
            return false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var s = await Auth.LoadAsync();
        if (s == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        _session = s;

        var (ok, room, err) = await Api.GetRoomAsync(RoomId);
        if (!ok || room == null)
        {
            _hubError = err ?? "Không tìm thấy phòng";
            _ready = true;
            StateHasChanged();
            return;
        }

        _room = room;
        _isCreator = string.Equals(room.CreatedBy, s.UserId.ToString(), StringComparison.OrdinalIgnoreCase);

        try
        {
            var hubUri = Nav.ToAbsoluteUri($"/gameHub?access_token={Uri.EscapeDataString(s.AccessToken)}");
            _hub = new HubConnectionBuilder()
                .WithUrl(hubUri)
                .WithAutomaticReconnect()
                .Build();

            _hub.On<string>("Error", msg =>
            {
                return InvokeAsync(() =>
                {
                    _hubError = msg;
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("PhaseChanged", payload =>
            {
                return InvokeAsync(() =>
                {
                    if (TryPhase(payload, out var ph))
                    {
                        _phase = ph;
                        if (IsRoundInfoPhase(ph))
                            _showRoundInfo = true;
                        if (IsCountdownPhase(ph) && !_phaseSecondsLeft.HasValue)
                            _phaseSecondsLeft = DefaultSecondsForPhase(ph);
                        if (string.Equals(ph, "reveal_countdown", StringComparison.OrdinalIgnoreCase)
                            || string.Equals(ph, "round_result", StringComparison.OrdinalIgnoreCase))
                        {
                            _phaseSecondsLeft = null;
                            _selectedMove = null;
                        }
                    }
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("TimerStarted", payload =>
            {
                if (!TryHubTimerPayload(payload, out var rid, out var ttype, out var sec))
                    return Task.CompletedTask;
                if (!string.Equals(rid, RoomId, StringComparison.OrdinalIgnoreCase))
                    return Task.CompletedTask;
                return InvokeAsync(() =>
                {
                    if (IsCountdownPhase(ttype))
                        _phaseSecondsLeft = sec;
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("TimerUpdate", payload =>
            {
                if (!TryHubTimerPayload(payload, out var rid, out var ttype, out var sec))
                    return Task.CompletedTask;
                if (!string.Equals(rid, RoomId, StringComparison.OrdinalIgnoreCase))
                    return Task.CompletedTask;
                return InvokeAsync(() =>
                {
                    if (IsCountdownPhase(ttype))
                        _phaseSecondsLeft = sec;
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("TimerCompleted", payload =>
            {
                if (!TryTimerCompleted(payload, out var rid, out var ttype))
                    return Task.CompletedTask;
                if (!string.Equals(rid, RoomId, StringComparison.OrdinalIgnoreCase))
                    return Task.CompletedTask;
                return InvokeAsync(() =>
                {
                    if (IsCountdownPhase(ttype))
                    {
                        _phaseSecondsLeft = null;
                        _selectedMove = null;
                    }
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("RoundCompleted", payload =>
            {
                return InvokeAsync(async () =>
                {
                    ClearRevealOverlay();
                    _selectedMove = null;
                    if (TryRoundSummary(payload, out var line))
                    {
                        _lastRound = line;
                        _roundHistory.Add(line);
                    }
                    StateHasChanged();
                    await RefreshRoomUiCoreAsync();
                });
            });

            _hub.On<JsonElement>("MovesLocked", payload =>
            {
                if (!TryMovesLocked(payload, out var u1, out var u2, out var endsUtc))
                    return Task.CompletedTask;

                return InvokeAsync(() =>
                {
                    _revealTickerCts?.Cancel();
                    _revealTickerCts?.Dispose();
                    _revealTickerCts = new CancellationTokenSource();

                    _revealMovesVisible = false;
                    _revealP1Move = null;
                    _revealP2Move = null;
                    _revealP1Username = u1;
                    _revealP2Username = u2;
                    _revealEndsAtUtc = endsUtc;
                    _revealVisible = true;
                    _phaseSecondsLeft = null;
                    _selectedMove = null;

                    _ = RunRevealTickerAsync(_revealTickerCts.Token);
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("MovesRevealed", payload =>
            {
                if (!TryMovesRevealed(payload, out var p1, out var p2, out var ru1, out var ru2))
                    return Task.CompletedTask;

                return InvokeAsync(() =>
                {
                    _revealP1Move = p1;
                    _revealP2Move = p2;
                    _revealP1Username = ru1;
                    _revealP2Username = ru2;
                    _revealMovesVisible = true;
                    StateHasChanged();
                });
            });

            _hub.On<JsonElement>("MoveSubmitted", _ => InvokeAsync(async () => await RefreshRoomUiCoreAsync()));
            _hub.On<JsonElement>("NextRound", _ =>
            {
                return InvokeAsync(async () =>
                {
                    ClearRevealOverlay();
                    _selectedMove = null;
                    StateHasChanged();
                    await RefreshRoomUiCoreAsync();
                });
            });
            _hub.On<JsonElement>("PlayerReadyChanged", _ => InvokeAsync(async () => await RefreshRoomUiCoreAsync()));
            _hub.On<JsonElement>("BothPlayersReady", _ =>
            {
                return InvokeAsync(async () =>
                {
                    _toast = "Cả hai đã sẵn sàng — chủ phòng có thể bắt đầu.";
                    await RefreshRoomUiCoreAsync();
                });
            });
            _hub.On<JsonElement>("GameEnded", payload =>
            {
                return InvokeAsync(async () =>
                {
                    ClearRevealOverlay();
                    _phaseSecondsLeft = null;
                    _selectedMove = null;
                    _showRoundInfo = false;
                    if (TryGameEndedWinner(payload, out var winnerName) && !string.IsNullOrWhiteSpace(winnerName))
                    {
                        _gameWinnerDisplay = winnerName.Trim();
                        _winnerPanelVisible = true;
                        _toast = null;
                    }
                    else
                    {
                        _gameWinnerDisplay = "";
                        _winnerPanelVisible = false;
                        _toast = "Trận đấu kết thúc.";
                    }
                    StateHasChanged();
                    await RefreshRoomUiCoreAsync();
                });
            });

            await _hub.StartAsync();

            var joinDto = new JoinRoomDto { RoomId = RoomId, PinCode = Pin ?? "" };
            await _hub.InvokeAsync("JoinRoom", joinDto);
        }
        catch (Exception ex)
        {
            _hubError = ex.Message;
        }

        _ready = true;
        StateHasChanged();
    }

    private Task RefreshRoomUiAsync() => RefreshRoomUiCoreAsync();

    private async Task RefreshRoomUiCoreAsync()
    {
        try
        {
            var (ok, room, _) = await Api.GetRoomAsync(RoomId);
            if (ok && room != null)
                _room = room;
        }
        catch { }

        await InvokeAsync(StateHasChanged);
    }

    private static bool TryPhase(JsonElement root, out string phase)
    {
        phase = "—";
        if (!root.TryGetProperty("data", out var d))
            return false;
        if (!d.TryGetProperty("phase", out var p))
            return false;
        phase = p.GetString() ?? phase;
        return true;
    }

    private static bool TryMovesLocked(JsonElement root, out string u1, out string u2, out DateTime endsUtc)
    {
        u1 = u2 = "";
        endsUtc = default;
        if (!root.TryGetProperty("data", out var d))
            return false;
        u1 = d.TryGetProperty("player1Username", out var x) ? x.GetString() ?? "P1" : "P1";
        u2 = d.TryGetProperty("player2Username", out var y) ? y.GetString() ?? "P2" : "P2";
        if (!d.TryGetProperty("revealEndsAt", out var re))
            return false;
        var iso = re.GetString();
        if (string.IsNullOrEmpty(iso))
            return false;
        if (!DateTime.TryParse(iso, null, DateTimeStyles.RoundtripKind, out var parsed))
            return false;
        endsUtc = parsed.Kind == DateTimeKind.Utc ? parsed : parsed.ToUniversalTime();
        return true;
    }

    private static bool TryMovesRevealed(JsonElement root, out string p1, out string p2, out string u1, out string u2)
    {
        p1 = p2 = u1 = u2 = "";
        if (!root.TryGetProperty("data", out var d))
            return false;
        p1 = d.TryGetProperty("player1Move", out var a) ? a.GetString() ?? "" : "";
        p2 = d.TryGetProperty("player2Move", out var b) ? b.GetString() ?? "" : "";
        u1 = d.TryGetProperty("player1Username", out var x) ? x.GetString() ?? "P1" : "P1";
        u2 = d.TryGetProperty("player2Username", out var y) ? y.GetString() ?? "P2" : "P2";
        return p1.Length > 0 && p2.Length > 0;
    }

    private static bool TryHubTimerPayload(JsonElement root, out string roomId, out string timerType, out int seconds)
    {
        roomId = "";
        timerType = "";
        seconds = 0;
        if (!root.TryGetProperty("roomId", out var r))
            return false;
        roomId = r.GetString() ?? "";
        if (!root.TryGetProperty("timerType", out var t))
            return false;
        timerType = t.GetString() ?? "";
        if (root.TryGetProperty("currentTime", out var c) && c.ValueKind == JsonValueKind.Number)
        {
            seconds = c.GetInt32();
            return true;
        }

        if (root.TryGetProperty("duration", out var d) && d.ValueKind == JsonValueKind.Number)
        {
            seconds = d.GetInt32();
            return true;
        }

        return false;
    }

    private static bool TryTimerCompleted(JsonElement root, out string roomId, out string timerType)
    {
        roomId = "";
        timerType = "";
        if (!root.TryGetProperty("roomId", out var r))
            return false;
        roomId = r.GetString() ?? "";
        if (!root.TryGetProperty("timerType", out var t))
            return false;
        timerType = t.GetString() ?? "";
        return true;
    }

    private static string MoveSvgSrc(string? move) => move?.ToLowerInvariant() switch
    {
        "rock" => "rps-moves/rock.svg",
        "paper" => "rps-moves/paper.svg",
        "scissors" => "rps-moves/scissors.svg",
        _ => "rps-moves/rock.svg"
    };

    private void ClearRevealOverlay()
    {
        _revealVisible = false;
        _revealMovesVisible = false;
        _revealP1Move = null;
        _revealP2Move = null;
        _revealTickerCts?.Cancel();
        _revealTickerCts?.Dispose();
        _revealTickerCts = null;
    }

    private static bool IsCountdownPhase(string? phaseOrTimerType) =>
        phaseOrTimerType != null
        && (phaseOrTimerType.Equals("betting_phase", StringComparison.OrdinalIgnoreCase)
            || phaseOrTimerType.Equals("battle_start", StringComparison.OrdinalIgnoreCase)
            || phaseOrTimerType.Equals("round_active", StringComparison.OrdinalIgnoreCase));

    private static int DefaultSecondsForPhase(string? phaseOrTimerType) => phaseOrTimerType?.ToLowerInvariant() switch
    {
        "betting_phase" => 10,
        "battle_start" => 5,
        "round_active" => 10,
        _ => 0
    };

    private static bool IsRoundInfoPhase(string? phase) =>
        phase != null
        && (phase.Equals("betting_phase", StringComparison.OrdinalIgnoreCase)
            || phase.Equals("battle_start", StringComparison.OrdinalIgnoreCase)
            || phase.Equals("round_active", StringComparison.OrdinalIgnoreCase)
            || phase.Equals("reveal_countdown", StringComparison.OrdinalIgnoreCase)
            || phase.Equals("round_result", StringComparison.OrdinalIgnoreCase)
            || phase.Equals("result_phase", StringComparison.OrdinalIgnoreCase));

    private string MoveButtonClass(string move)
    {
        var selected = string.Equals(_selectedMove, move, StringComparison.OrdinalIgnoreCase);
        return selected
            ? "btn rps-play-move rps-play-move--icon rps-play-move--selected"
            : "btn rps-play-move rps-play-move--icon";
    }

    private async Task RunRevealTickerAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested && _revealVisible)
            {
                await Task.Delay(200, ct);
                await InvokeAsync(StateHasChanged);
                if (DateTime.UtcNow >= _revealEndsAtUtc)
                    break;
            }
        }
        catch (OperationCanceledException)
        {
            // bình thường khi đóng overlay
        }
    }

    private static bool TryGameEndedWinner(JsonElement root, out string? winnerUsername)
    {
        winnerUsername = null;
        if (!root.TryGetProperty("data", out var d))
            return false;
        if (!d.TryGetProperty("winnerUsername", out var w))
            return false;
        winnerUsername = w.GetString();
        return true;
    }

    private void DismissWinnerPanel()
    {
        _winnerPanelVisible = false;
    }

    private static bool TryRoundSummary(JsonElement root, out string line)
    {
        line = "";
        if (!root.TryGetProperty("data", out var d))
            return false;
        var p1 = d.TryGetProperty("player1Move", out var a) ? a.GetString() : null;
        var p2 = d.TryGetProperty("player2Move", out var b) ? b.GetString() : null;
        var u1 = d.TryGetProperty("player1Username", out var x) ? x.GetString() : "?";
        var u2 = d.TryGetProperty("player2Username", out var y) ? y.GetString() : "?";
        var res = d.TryGetProperty("result", out var r) ? r.GetString() : "";
        line = $"{u1} ({p1}) vs {u2} ({p2}) → {res}";
        return true;
    }

    private async Task SetReadyAsync(bool isReady)
    {
        if (_hub == null)
            return;
        _hubBusy = true;
        try
        {
            await _hub.InvokeAsync("SetPlayerReady", RoomId, isReady);
            await RefreshRoomUiAsync();
        }
        finally
        {
            _hubBusy = false;
        }
    }

    private async Task StartGameAsync()
    {
        if (_hub == null)
            return;
        _hubBusy = true;
        try
        {
            await _hub.InvokeAsync("StartGame", RoomId);
            _phaseSecondsLeft = 10;
            _selectedMove = null;
            _roundHistory.Clear();
            _lastRound = null;
            _showRoundInfo = true;
            await RefreshRoomUiAsync();
        }
        finally
        {
            _hubBusy = false;
        }
    }

    private async Task MoveAsync(string move)
    {
        if (_hub == null)
            return;
        _hubBusy = true;
        _selectedMove = move;
        try
        {
            await _hub.InvokeAsync("SubmitMove", RoomId, move);
            await RefreshRoomUiAsync();
        }
        finally
        {
            _hubBusy = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        ClearRevealOverlay();
        _winnerPanelVisible = false;
        if (_hub != null)
            await _hub.DisposeAsync();
    }
}
