@page "/portal"
@rendermode InteractiveServer
@inject AuthTokenStore Auth

<PageTitle>Trung tâm ứng dụng</PageTitle>

@if (_checked && !_loggedIn)
{
    <div class="rps-portal-guest card shadow-sm border-0">
        <div class="card-body text-center py-5 px-4">
            <h1 class="h4 mb-2">RPS Online</h1>
            <p class="text-muted mb-4 mx-auto" style="max-width: 22rem">
                Đăng nhập để mở menu đầy đủ và dùng các module (sảnh, lịch sử, dashboard, công cụ API…).
            </p>
            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <a class="btn btn-primary" href="/login">Đăng nhập</a>
                <a class="btn btn-outline-primary" href="/register">Đăng ký</a>
            </div>
            <p class="small text-muted mt-4 mb-0"><a href="/">Trang chủ Razor</a></p>
        </div>
    </div>
}
else if (_loggedIn)
{
    <h1 class="h3 mb-4">Trung tâm (tất cả API)</h1>
    <p class="text-muted">Chọn module — đã đăng nhập với tài khoản của bạn.</p>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h6">Chơi</h2>
                    <ul class="small mb-0">
                        <li><a href="/lobby">Sảnh phòng</a></li>
                        <li><a href="/history">Lịch sử trận</a></li>
                        <li><a href="/tools/rooms">Phòng (API)</a></li>
                        <li><a href="/tools/game">Game REST</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h6">Cộng đồng &amp; điểm</h2>
                    <ul class="small mb-0">
                        <li><a href="/dashboard">Dashboard</a></li>
                        <li><a href="/leaderboard">Bảng xếp hạng</a></li>
                        <li><a href="/players">Người chơi</a></li>
                        <li><a href="/me">Hồ sơ &amp; profile API</a></li>
                        <li><a href="/me/points">Điểm</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h6">Chat, cược, vận hành</h2>
                    <ul class="small mb-0">
                        <li><a href="/tools/chat">Chat &amp; activity</a></li>
                        <li><a href="/tools/betting">Betting</a></li>
                        <li><a href="/tools/room-management">Room management</a></li>
                        <li><a href="/tools/health">Health checks</a></li>
                        <li><a href="/tools/api-map">Bản đồ API → UI</a></li>
                        <li><a href="/tools/api-explorer">API explorer</a></li>
                        <li><a href="/account">Tài khoản &amp; token</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <p class="mt-3 small"><a href="/">← Razor trang chủ</a></p>
}
else
{
    <p class="text-muted">Đang tải…</p>
}

@code {
    private bool _checked;
    private bool _loggedIn;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var s = await Auth.LoadAsync();
        _loggedIn = s != null && !string.IsNullOrWhiteSpace(s.AccessToken);
        _checked = true;
        StateHasChanged();
    }
}
