@page "/me/bets"
@rendermode InteractiveServer
@using System.Text.Json
@inject GameApiService Api
@inject AuthTokenStore Auth

<PageTitle>Lịch sử cược</PageTitle>

@if (!_ready)
{
    <p class="px-2">Đang tải…</p>
}
else if (_session == null)
{
    <p class="px-2 small">Vui lòng <a href="/login">đăng nhập</a> để xem lịch sử cược.</p>
}
else
{
    <div class="container py-3">
        <div class="rps-community-shell px-0">
            <header class="rps-community-hero mb-3">
                <p class="rps-community-kicker"><i class="bi bi-clock-history" aria-hidden="true"></i> Lịch sử cược</p>
                <h1 class="rps-community-title mb-1">Lịch sử cược</h1>
                <p class="text-muted small mb-0">Theo dõi các lần đặt cược và biến động xu của tài khoản.</p>
            </header>

            <nav class="rps-hub-quicklinks mb-3" aria-label="Liên kết nhanh">
                <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
            </nav>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2 small">@_error</div>
        }

        @if (_active.Count == 0 && _completed.Count == 0)
        {
            <p class="text-muted small mb-0">Bạn chưa có cược nào.</p>
        }
        else
        {
            @if (_active.Count > 0)
            {
                <section class="mb-4">
                    <div class="card border-0 shadow-sm bg-dark text-light">
                        <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small text-uppercase text-muted fw-semibold">Cược đang chờ kết quả</div>
                                <div class="small text-muted mb-0">@_active.Count phiếu cược đang mở</div>
                            </div>
                        </div>
                        <div class="card-body py-2">
                            <div class="table-responsive small">
                                <table class="table table-sm align-middle mb-0 table-dark table-hover">
                                    <thead>
                                        <tr>
                                            <th>Phòng</th>
                                            <th>Số xu</th>
                                            <th>Thời gian</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var b in _active)
                                        {
                                            <tr>
                                                <td>
                                                    <span class="badge rounded-pill bg-info text-dark"
                                                          title="@b.GameId">
                                                        @GetRoomDisplay(b.GameId)
                                                    </span>
                                                </td>
                                                <td>@b.Amount.ToString("N0")</td>
                                                <td>@b.Timestamp.ToLocalTime().ToString("g")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </section>
            }

            @if (_completed.Count > 0)
            {
                <section>
                    <div class="card border-0 shadow-sm bg-dark text-light">
                        <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small text-uppercase text-muted fw-semibold">Cược đã kết thúc</div>
                                <div class="small text-muted mb-0">@_completed.Count phiếu cược đã hoàn tất</div>
                            </div>
                        </div>
                        <div class="card-body py-2">
                            <div class="table-responsive small">
                                <table class="table table-sm align-middle mb-0 table-dark table-hover">
                                    <thead>
                                        <tr>
                                            <th>Phòng</th>
                                            <th>Đã cược</th>
                                            <th>Kết quả</th>
                                            <th>Lãi / Lỗ</th>
                                            <th>Thời gian</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var b in _completed)
                                        {
                                            var payout = b.Payout ?? 0;
                                            var delta = payout - b.Amount;
                                            var win = delta > 0;
                                            <tr class="@(win ? "table-success" : "table-secondary")">
                                                <td>
                                                    <span class="badge rounded-pill bg-info text-dark"
                                                          title="@b.GameId">
                                                        @GetRoomDisplay(b.GameId)
                                                    </span>
                                                </td>
                                                <td>@b.Amount.ToString("N0") xu</td>
                                                <td>@payout.ToString("N0") xu</td>
                                                <td>
                                                    @if (delta > 0)
                                                    {
                                                        <span class="text-success">+@delta.ToString("N0") xu</span>
                                                    }
                                                    else if (delta < 0)
                                                    {
                                                        <span class="text-danger">@delta.ToString("N0") xu</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">0 xu</span>
                                                    }
                                                </td>
                                                <td>@b.Timestamp.ToLocalTime().ToString("g")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </section>
            }
        }
    </div>
}

@code {
    private PortalAuthState? _session;
    private bool _ready;
    private string? _error;
    private readonly List<BetResponseDto> _active = [];
    private readonly List<BetResponseDto> _completed = [];

    private static string GetRoomDisplay(string? gameId)
    {
        if (string.IsNullOrWhiteSpace(gameId))
            return "Phòng ?";

        var trimmed = gameId.Trim();
        if (trimmed.Length <= 6)
            return $"Phòng {trimmed}";

        return $"Phòng {trimmed[..6]}…";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _session = await Auth.LoadAsync();
        if (_session == null)
        {
            _ready = true;
            StateHasChanged();
            return;
        }

        var (ok, data, err) = await Api.BettingGetMyBetsAsync();
        if (!ok || data is null)
        {
            _error = err ?? "Không tải được lịch sử cược.";
            _ready = true;
            StateHasChanged();
            return;
        }

        try
        {
            if (data is JsonElement el)
            {
                ParseBetsElement(el);
            }
        }
        catch
        {
            _error = "Định dạng dữ liệu lịch sử cược không hợp lệ.";
        }

        _ready = true;
        StateHasChanged();
    }

    private void ParseBetsElement(JsonElement root)
    {
        if (root.TryGetProperty("activeBets", out var activeEl) && activeEl.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in activeEl.EnumerateArray())
            {
                var bet = JsonSerializer.Deserialize<BetResponseDto>(item.GetRawText(), new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (bet != null)
                    _active.Add(bet);
            }
        }

        if (root.TryGetProperty("completedBets", out var completedEl) && completedEl.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in completedEl.EnumerateArray())
            {
                var bet = JsonSerializer.Deserialize<BetResponseDto>(item.GetRawText(), new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (bet != null)
                    _completed.Add(bet);
            }
        }
    }
}

