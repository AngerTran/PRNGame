@page "/tools/game"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth

<PageTitle>Game REST</PageTitle>

<div class="rps-community-shell rps-tools-page">
    <header class="rps-community-hero">
        <p class="rps-community-kicker"><i class="bi bi-joystick" aria-hidden="true"></i> REST · Ván</p>
        <h1 class="rps-community-title">Game REST API</h1>
        <p class="text-muted small mb-0">Song song với SignalR trong sảnh — gọi thủ công để thử luồng máy chủ.</p>
    </header>
    <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
        <a class="rps-hub-pill" href="/portal"><i class="bi bi-cpu" aria-hidden="true"></i>Trung tâm</a>
        <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
    </nav>

    @if (_session == null)
    {
        <div class="card rps-tools-guest border-secondary">
            <div class="card-body text-center">
                <p class="text-muted small mb-3 mb-md-0">Đăng nhập để gọi Game REST với token của bạn.</p>
                <a class="btn btn-primary btn-sm" href="/login">Đăng nhập</a>
            </div>
        </div>
    }
    else
    {
        <div class="card mb-4 rps-tools-room-card">
            <div class="card-header">
                <i class="bi bi-hash" aria-hidden="true"></i>
                Phòng (roomId)
            </div>
            <div class="card-body">
                <label class="rps-tools-field-label" for="rps-game-room">roomId</label>
                <input id="rps-game-room" class="form-control" @bind="_roomId" placeholder="roomId" autocomplete="off" />
            </div>
        </div>

        <div class="row g-4 align-items-stretch">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-lightning-charge-fill" aria-hidden="true"></i>
                        Luồng &amp; trạng thái
                    </div>
                    <div class="card-body">
                        <div class="rps-tools-btn-grid rps-tools-state-btns">
                            <button type="button" class="btn btn-sm btn-primary" @onclick="@(() => Run(() => Api.GameStartAsync(_roomId)))">
                                <i class="bi bi-play-fill" aria-hidden="true"></i>start
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="@(() => Run(() => Api.GameSetReadyAsync(_roomId, true)))">
                                <i class="bi bi-check2-circle" aria-hidden="true"></i>ready true
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => Run(() => Api.GameSetReadyAsync(_roomId, false)))">
                                <i class="bi bi-x-circle" aria-hidden="true"></i>ready false
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-dark" @onclick="@(() => Run(() => Api.GameGetStateAsync(_roomId)))">
                                <i class="bi bi-activity" aria-hidden="true"></i>state
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-dark" @onclick="@(() => Run(() => Api.GameGetReadyStatesAsync(_roomId)))">
                                <i class="bi bi-people" aria-hidden="true"></i>ready-states
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-hand-index-thumb" aria-hidden="true"></i>
                        Nước đi
                    </div>
                    <div class="card-body">
                        <div class="rps-tools-btn-grid rps-game-move">
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => Run(() => Api.GameSubmitMoveAsync(_roomId, "rock")))">
                                <i class="bi bi-circle-fill" aria-hidden="true"></i>rock
                            </button>
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => Run(() => Api.GameSubmitMoveAsync(_roomId, "paper")))">
                                <i class="bi bi-file-earmark" aria-hidden="true"></i>paper
                            </button>
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => Run(() => Api.GameSubmitMoveAsync(_roomId, "scissors")))">
                                <i class="bi bi-scissors" aria-hidden="true"></i>scissors
                            </button>
                            <button type="button" class="btn btn-sm btn-warning" @onclick="@(() => Run(() => Api.GameProcessRoundAsync(_roomId)))">
                                <i class="bi bi-trophy" aria-hidden="true"></i>round/result
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-flag-fill" aria-hidden="true"></i>
                        Kết thúc trận
                    </div>
                    <div class="card-body">
                        <label class="rps-tools-field-label" for="rps-game-winner">winnerId (end / result)</label>
                        <div class="rps-tools-result-wrap mb-3">
                            <input id="rps-game-winner" class="form-control form-control-sm" @bind="_winner" placeholder="winnerId (end / result)" autocomplete="off" />
                        </div>
                        <div class="rps-tools-btn-grid">
                            <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => Run(() => Api.GameEndAsync(_roomId, string.IsNullOrWhiteSpace(_winner) ? null : _winner.Trim())))">
                                <i class="bi bi-stop-circle" aria-hidden="true"></i>end
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => Run(() => Api.GameProcessResultAsync(_roomId, string.IsNullOrWhiteSpace(_winner) ? null : _winner.Trim())))">
                                <i class="bi bi-clipboard-check" aria-hidden="true"></i>result
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <JsonApiResult Json="@_json" Error="@_err" />
        </div>
    }
</div>

@code {
    private PortalAuthState? _session;
    private string _roomId = "";
    private string _winner = "";
    private string? _json;
    private string? _err;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        StateHasChanged();
    }

    private async Task Run(Func<Task<(bool Ok, string Body, string? Error)>> fn)
    {
        _err = null; _json = null;
        var (ok, body, err) = await fn();
        _json = ok ? body : null;
        _err = err;
    }
}
