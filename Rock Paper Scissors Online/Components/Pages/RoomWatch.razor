@page "/watch/{RoomId}"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Text.Json
@using Rock_Paper_Scissors_Online.DTOs
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager Nav

<PageTitle>Xem trận · @RoomId</PageTitle>

@if (!_ready)
{
    <p class="px-2">Đang tải…</p>
}
else if (_session == null)
{
    <p class="px-2"><a href="/login">Đăng nhập</a> để xem và cược.</p>
}
else
{
    <div class="rps-watch-shell px-2 py-3">
        <header class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
            <div>
                <p class="small text-muted mb-1">Theo dõi trận</p>
                <h1 class="h4 mb-0">@(_room?.Name ?? "Phòng")</h1>
            </div>
            <nav class="rps-hub-quicklinks mb-0" aria-label="Liên kết nhanh">
                <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
                <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
            </nav>
        </header>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }
        @if (!string.IsNullOrEmpty(_toast))
        {
            <div class="alert alert-info py-2 small">@_toast</div>
        }

        @if (_myBetPanelVisible)
        {
            <div class="alert @( _myBetDelta >= 0 ? "alert-success" : "alert-secondary" ) py-2 small mb-3">
                <div class="fw-semibold mb-1">Kết quả cược của bạn</div>
                <div>
                    Cược @(_myBetAmount.ToString("N0")) xu ·
                    @( _myBetDelta >= 0 ? "Lãi" : "Lỗ" )
                    @Math.Abs(_myBetDelta).ToString("N0") xu ·
                    Tổng điểm hiện tại: <strong>@_currentPoints.ToString("N0") xu</strong>
                </div>
            </div>
        }

        @if (_room == null)
        {
            <p class="text-muted">Không tìm thấy phòng.</p>
        }
        else if (!_room.AllowBetting)
        {
            <p class="text-muted">Phòng này không bật cược.</p>
        }
        else if (!ShouldShowBettingUi(_room))
        {
            <p class="text-muted">Chỉ hiện chọn mức cược khi phòng có 2 người chơi và cả hai đã sẵn sàng.</p>
            <p class="small">Trạng thái hiện tại: <strong>@_room.Status</strong> · Người chơi: @_room.CurrentPlayers/@_room.MaxPlayers</p>
        }
        else
        {
            @if (_room.IsPrivate)
            {
                <div class="mb-3">
                    <label class="form-label small">Mã PIN phòng riêng (bắt buộc để cược)</label>
                    <input class="form-control form-control-sm" style="max-width:12rem" maxlength="8" autocomplete="off"
                           placeholder="PIN" @bind="_pin" @bind:event="oninput" />
                </div>
            }

            <div class="rps-watch-vs card border-secondary bg-dark text-light mb-3">
                <div class="card-body">
                    <div class="row g-2 text-center">
                        <div class="col-5">
                            <div class="small text-muted">Người chơi 1</div>
                            <div class="fw-bold">@P1Name</div>
                            <div class="small">Điểm: @ScoreP1</div>
                        </div>
                        <div class="col-2 align-self-center text-muted small">vs</div>
                        <div class="col-5">
                            <div class="small text-muted">Người chơi 2</div>
                            <div class="fw-bold">@P2Name</div>
                            <div class="small">Điểm: @ScoreP2</div>
                        </div>
                    </div>
                </div>
            </div>

            <section class="mb-3">
                <div class="small text-muted mb-2">Chọn mức cược (xu)</div>
                <div class="btn-group flex-wrap" role="group">
                    @foreach (var a in _stakes)
                    {
                        var active = _selectedStake == a;
                        <button type="button" class="btn btn-sm @(active ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => _selectedStake = a">@a</button>
                    }
                </div>
            </section>

            <section class="mb-3">
                <div class="small text-muted mb-2">Đặt cược — người thắng trận nhận pool theo tỉ lệ (đã trừ xu lúc đặt)</div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-success" type="button" disabled="@(_busy || P1Id == null)" @onclick="() => PlaceAsync(P1Id!)">
                        Cược @P1Name
                    </button>
                    <button class="btn btn-outline-success" type="button" disabled="@(_busy || P2Id == null)" @onclick="() => PlaceAsync(P2Id!)">
                        Cược @P2Name
                    </button>
                </div>
                <p class="small text-muted mt-2 mb-0">Mỗi tài khoản chỉ được đặt <strong>1 lần cược</strong> cho cả trận. Người đang thi đấu không được cược.</p>
            </section>

            @if (_pool != null)
            {
                <section class="rps-watch-pool card border-0 bg-dark bg-opacity-50 text-light mb-0">
                    <div class="card-body py-3">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <div>
                                <div class="small text-muted text-uppercase mb-1">Tổng pool</div>
                                <div class="fs-5 fw-semibold">@_pool.TotalPool.ToString("N0") xu</div>
                                @if (_pool.TotalBets > 0)
                                {
                                    <div class="small text-muted">Số vé cược: @_pool.TotalBets</div>
                                }
                                else
                                {
                                    <div class="small text-muted">Chưa có ai cược, bạn sẽ là người đầu tiên.</div>
                                }
                            </div>
                            <div class="rps-watch-pool-sides d-flex flex-column flex-md-row gap-3">
                                <div class="rps-watch-pool-side">
                                    <div class="small text-muted mb-1">Cược cho @P1Name</div>
                                    <div class="fw-semibold">
                                        @_pool.Player1Total.ToString("N0") xu
                                        <span class="small text-muted">(@_pool.Player1Percentage.ToString("0")%)</span>
                                    </div>
                                    <div class="small text-success">
                                        Lợi nhuận dự kiến: @_pool.Player1PotentialProfit.ToString("0")%
                                    </div>
                                </div>
                                <div class="rps-watch-pool-side">
                                    <div class="small text-muted mb-1">Cược cho @P2Name</div>
                                    <div class="fw-semibold">
                                        @_pool.Player2Total.ToString("N0") xu
                                        <span class="small text-muted">(@_pool.Player2Percentage.ToString("0")%)</span>
                                    </div>
                                    <div class="small text-success">
                                        Lợi nhuận dự kiến: @_pool.Player2PotentialProfit.ToString("0")%
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            }
        }
    </div>
}

@code {
    [Parameter] public string RoomId { get; set; } = "";
    [SupplyParameterFromQuery] public string? Pin { get; set; }

    private PortalAuthState? _session;
    private RoomResponseDto? _room;
    private bool _ready;
    private bool _busy;
    private string? _error;
    private string? _toast;
    private string _pin = "";
    private decimal _selectedStake = 50;
    private static readonly decimal[] _stakes = { 25m, 50m, 100m, 150m };
    private BettingPoolUi? _pool;
    private CancellationTokenSource? _watchLoopCts;

    private bool _myBetPanelVisible;
    private decimal _myBetAmount;
    private decimal _myBetPayout;
    private decimal _myBetDelta;
    private long _currentPoints;

    private string? P1Id => _room?.Player1?.UserId;
    private string? P2Id => _room?.Player2?.UserId;
    private string P1Name => _room?.Player1?.Username ?? "—";
    private string P2Name => _room?.Player2?.Username ?? "—";

    private int ScoreP1 => _room?.PlayerScores?.GetValueOrDefault(P1Id ?? "", 0) ?? 0;
    private int ScoreP2 => _room?.PlayerScores?.GetValueOrDefault(P2Id ?? "", 0) ?? 0;

    private static bool ShouldShowBettingUi(RoomResponseDto r)
    {
        if (r.CurrentPlayers < 2 || r.Player1 == null || r.Player2 == null)
            return false;

        var status = (r.Status ?? "").Trim().ToLowerInvariant();
        var bothReady = r.Player1.IsReady && r.Player2.IsReady;

        // Hiện UI cược khi:
        // - Phòng đang chờ (waiting) nhưng đủ 2 người và cả hai đã sẵn sàng
        // - Hoặc trận đã bắt đầu (playing/inprogress) để người xem tiếp tục theo dõi pool
        if (status == "waiting")
            return bothReady;

        return status == "playing" || status == "inprogress";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var s = await Auth.LoadAsync();
        if (s == null)
        {
            _ready = true;
            StateHasChanged();
            return;
        }

        _session = s;
        if (!string.IsNullOrWhiteSpace(Pin))
            _pin = Pin.Trim();

        var (ok, room, err) = await Api.GetRoomAsync(RoomId);
        if (!ok || room == null)
            _error = err ?? "Không tải được phòng.";
        else
            _room = room;

        _ready = true;
        if (_room != null && ShouldShowBettingUi(_room))
            _ = RefreshPoolQuietAsync();

        if (_room != null)
            StartWatchLoop();

        StateHasChanged();
    }

    private async Task RefreshPoolQuietAsync()
    {
        var (ok, body, _) = await Api.BettingGetPoolAsync(RoomId);
        if (!ok || string.IsNullOrEmpty(body))
            return;

        try
        {
            using var doc = JsonDocument.Parse(body);
            if (!doc.RootElement.TryGetProperty("data", out var d))
                d = doc.RootElement;

            _pool = new BettingPoolUi
            {
                TotalPool = d.TryGetProperty("totalPool", out var tp) ? tp.GetDecimal() : 0m,
                TotalBets = d.TryGetProperty("totalBets", out var tb) ? tb.GetInt32() : 0,
                Player1Total = d.TryGetProperty("player1Total", out var p1t) ? p1t.GetDecimal() : 0m,
                Player2Total = d.TryGetProperty("player2Total", out var p2t) ? p2t.GetDecimal() : 0m,
                Player1PotentialProfit = d.TryGetProperty("player1PotentialProfit", out var p1p) ? p1p.GetDecimal() : 0m,
                Player2PotentialProfit = d.TryGetProperty("player2PotentialProfit", out var p2p) ? p2p.GetDecimal() : 0m,
                Player1Percentage = d.TryGetProperty("bettingDistribution", out var dist) && dist.TryGetProperty("player1Percentage", out var p1perc)
                    ? p1perc.GetDecimal()
                    : 0m,
                Player2Percentage = d.TryGetProperty("bettingDistribution", out dist) && dist.TryGetProperty("player2Percentage", out var p2perc)
                    ? p2perc.GetDecimal()
                    : 0m
            };
        }
        catch
        {
            _pool = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void StartWatchLoop()
    {
        _watchLoopCts?.Cancel();
        _watchLoopCts?.Dispose();
        _watchLoopCts = new CancellationTokenSource();
        var token = _watchLoopCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(TimeSpan.FromSeconds(3), token);
                    if (token.IsCancellationRequested)
                        break;

                    var (okRoom, room, _) = await Api.GetRoomAsync(RoomId);
                    if (!okRoom || room == null)
                        continue;

                    if (string.Equals(room.Status, "Finished", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(room.Status, "Completed", StringComparison.OrdinalIgnoreCase))
                    {
                        await LoadMyBetResultAsync();
                        break;
                    }
                }
            }
            catch (TaskCanceledException)
            {
                // ignore
            }
        }, token);
    }

    private async Task LoadMyBetResultAsync()
    {
        if (_session == null)
            return;

        // Lấy lịch sử cược của chính user
        var (okBets, data, _) = await Api.BettingGetMyBetsAsync();
        if (okBets && data is JsonElement el)
        {
            BetResponseDto? bet = null;

            if (el.TryGetProperty("completedBets", out var completed) && completed.ValueKind == JsonValueKind.Array)
            {
                foreach (var item in completed.EnumerateArray())
                {
                    var b = JsonSerializer.Deserialize<BetResponseDto>(item.GetRawText(),
                        new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (b != null && string.Equals(b.GameId, RoomId, StringComparison.OrdinalIgnoreCase))
                    {
                        bet = b;
                        break;
                    }
                }
            }

            if (bet != null)
            {
                _myBetAmount = bet.Amount;
                _myBetPayout = bet.Payout ?? 0;
                _myBetDelta = _myBetPayout - _myBetAmount;
                _myBetPanelVisible = true;
            }
        }

        // Lấy lại tổng điểm hiện tại
        var (okPts, pts, _) = await Api.GetCurrentPointsAsync();
        if (okPts)
            _currentPoints = pts;

        await InvokeAsync(StateHasChanged);
    }

    private async Task PlaceAsync(string targetPlayerId)
    {
        if (_session == null || _room == null)
            return;
        _busy = true;
        _toast = null;
        _error = null;
        try
        {
            if (_room.IsPrivate && string.IsNullOrWhiteSpace(_pin))
            {
                _error = "Nhập mã PIN phòng riêng.";
                return;
            }

            var (ok, _, err) = await Api.BettingPlaceAsync(RoomId, _selectedStake, targetPlayerId,
                _room.IsPrivate ? _pin.Trim() : null);
            if (!ok)
            {
                _error = err ?? "Đặt cược thất bại.";
                return;
            }

            _toast = $"Đã đặt cược {_selectedStake} xu.";
            await RefreshPoolQuietAsync();
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private sealed class BettingPoolUi
    {
        public decimal TotalPool { get; set; }
        public int TotalBets { get; set; }
        public decimal Player1Total { get; set; }
        public decimal Player2Total { get; set; }
        public decimal Player1Percentage { get; set; }
        public decimal Player2Percentage { get; set; }
        public decimal Player1PotentialProfit { get; set; }
        public decimal Player2PotentialProfit { get; set; }
    }

    public ValueTask DisposeAsync()
    {
        _watchLoopCts?.Cancel();
        _watchLoopCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
