@page "/history"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager Nav

<PageTitle>Lịch sử</PageTitle>

@if (!_ready)
{
    <div class="rps-community-shell">
        <p class="rps-community-loading mb-0">Đang tải…</p>
    </div>
}
else
{
    <div class="rps-community-shell">
        <header class="rps-community-hero">
            <p class="rps-community-kicker"><i class="bi bi-clock-history" aria-hidden="true"></i> Lịch sử trận</p>
            <h1 class="rps-community-title">Lịch sử</h1>
            <p class="text-muted small mb-0">Xem trận đã chơi và giao dịch điểm từ API.</p>
        </header>

        <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
            <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
            <a class="rps-hub-pill" href="/portal"><i class="bi bi-cpu" aria-hidden="true"></i>Trung tâm</a>
            <a class="rps-hub-pill" href="/"><i class="bi bi-house" aria-hidden="true"></i>Razor</a>
        </nav>

        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button type="button" class="nav-link @Tc(0)" @onclick='() => _tab=0'>Trận đã chơi</button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @Tc(1)" @onclick='() => _tab=1'>Giao dịch điểm</button>
            </li>
        </ul>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (_tab == 0)
        {
            <div class="table-responsive rps-history-table-wrap">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Thời gian</th>
                            <th scope="col">Đối thủ</th>
                            <th scope="col">Kết quả</th>
                            <th scope="col">± Điểm</th>
                            <th scope="col">Ván</th>
                            <th scope="col">Phòng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_matches.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="p-0 border-0">
                                    <p class="rps-history-empty mb-0">
                                        <strong>Chưa có trận nào</strong>
                                        Vào sảnh để chơi — dữ liệu lấy từ API lịch sử trận.
                                    </p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var m in _matches)
                            {
                                <tr>
                                    <td>@m.PlayedAt.ToLocalTime().ToString("g")</td>
                                    <td>@m.OpponentUsername</td>
                                    <td>@FormatMatchResult(m.Result)</td>
                                    <td>@FormatDelta(m)</td>
                                    <td>@m.RoundsPlayed</td>
                                    <td>@m.RoomName</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <p class="rps-history-api-hint">
                <i class="bi bi-link-45deg" aria-hidden="true"></i>
                <span>GET <code class="mb-0">api/v1/match-history/&#123;userId&#125;</code></span>
            </p>
        }
        else
        {
            <div class="rps-community-toolbar">
                <button type="button" class="btn btn-sm btn-primary" @onclick="LoadTxAsync">Tải giao dịch điểm</button>
            </div>
            @if (!_txRequested)
            {
                <p class="rps-history-empty">
                    <strong>Chưa tải dữ liệu</strong>
                    Nhấn nút trên để gọi API giao dịch điểm (trang 1, tối đa 50 bản ghi).
                </p>
            }
            else if ((_tx?.Transactions?.Count ?? 0) == 0)
            {
                <p class="rps-history-empty">
                    <strong>Không có giao dịch</strong>
                    Không có bản ghi nào trong trang này hoặc không tải được — kiểm tra thông báo lỗi phía trên nếu có.
                </p>
            }
            <div class="table-responsive rps-history-table-wrap">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Thời gian</th>
                            <th scope="col">Δ</th>
                            <th scope="col">Mô tả</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _tx?.Transactions ?? new List<PointTransactionDto>())
                        {
                            <tr>
                                <td>@t.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>@t.Delta</td>
                                <td>@t.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="rps-history-api-hint">
                <i class="bi bi-link-45deg" aria-hidden="true"></i>
                <span>GET <code class="mb-0">api/v1/.../transactions</code></span>
            </p>
        }
    </div>
}

@code {
    private bool _ready;
    private int _tab;
    private string? _error;
    private List<MatchHistoryDto> _matches = new();
    private PointTransactionHistoryResponse? _tx;
    private bool _txRequested;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var s = await Auth.LoadAsync();
        if (s == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var (ok, data, err) = await Api.GetMatchHistoryAsync(s.UserId);
        if (!ok || data == null)
            _error = err ?? "Không tải được lịch sử";
        else
            _matches = data.Matches;

        _ready = true;
        StateHasChanged();
    }

    private string Tc(int i) => _tab == i ? "active" : "";

    private static string FormatMatchResult(string r) => r.ToLowerInvariant() switch
    {
        "win" => "Thắng",
        "loss" => "Thua",
        "draw" => "Hòa",
        _ => r
    };

    private static string FormatDelta(MatchHistoryDto m)
    {
        if (m.PointsEarned > 0) return $"+{m.PointsEarned}";
        if (m.PointsLost > 0) return $"-{m.PointsLost}";
        return "—";
    }

    private async Task LoadTxAsync()
    {
        var s = await Auth.LoadAsync();
        if (s == null) return;
        _txRequested = true;
        var (ok, data, err) = await Api.GetPointTransactionsAsync(s.UserId, 1, 50);
        _tx = data;
        if (!ok) _error = err;
        StateHasChanged();
    }
}
