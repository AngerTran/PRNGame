@page "/players"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager NavigationManager

<PageTitle>Người chơi</PageTitle>

<div class="rps-community-shell players-hub-page">
    <header class="rps-community-hero players-hero">
        <p class="rps-community-kicker"><i class="bi bi-people" aria-hidden="true"></i> Cộng đồng</p>
        <h1 class="rps-community-title">Người chơi &amp; lời mời</h1>
        <p class="players-hero-subtitle">Mời bạn bè thi đấu, theo dõi người chơi online và xử lý lời mời đến.</p>
    </header>
    <nav class="rps-hub-quicklinks mb-3" aria-label="Liên kết nhanh">
        <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
    </nav>

    @if (!string.IsNullOrEmpty(_toastOk))
    {
        <div class="alert alert-success py-2 small mb-3" role="status">@_toastOk</div>
    }
    @if (!string.IsNullOrEmpty(_toastErr))
    {
        <div class="alert alert-danger py-2 small mb-3" role="alert">@_toastErr</div>
    }

    <div class="players-status-row mb-3">
        <span class="players-chip"><i class="bi bi-wifi"></i> Online: @_onlineDisplayRows.Count</span>
        <span class="players-chip"><i class="bi bi-chat-dots"></i> Lời mời chờ: @_invitations.Count</span>
    </div>

    <div class="players-toolbar d-flex flex-wrap gap-2 align-items-center mb-3">
        <button class="btn btn-primary" type="button" disabled="@_loadingOnline" @onclick="RefreshOnlineAsync">
            @if (_loadingOnline) { <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> }
            Làm mới
        </button>
        <button class="btn btn-outline-light" type="button" @onclick="ToggleAutoRefresh">
            @(_autoRefreshEnabled ? "Tắt tự động" : "Bật tự động")
        </button>
        <span class="small text-muted">Tự cập nhật mỗi 5 giây</span>
        @if (_session != null)
        {
            <button class="btn btn-outline-light" type="button" disabled="@_loadingOnline" @onclick="RefreshInvitationsButtonAsync">Làm mới lời mời</button>
        }
    </div>

    @if (_session == null)
    {
        <div class="alert alert-info py-2 mb-3 small">Đăng nhập để xem danh sách chi tiết, gửi lời mời và đồng ý/từ chối lời mời.</div>
    }

    <div class="card border-0 shadow-sm players-card">
        <div class="card-header bg-transparent py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <strong><i class="bi bi-people me-1" aria-hidden="true"></i>Người chơi online</strong>
            @if (_onlineListSource == OnlineListSource.PlayerStats)
            {
                <span class="badge text-bg-primary">Chi tiết</span>
            }
            else if (_onlineListSource == OnlineListSource.Legacy)
            {
                <span class="badge text-bg-secondary">Công khai</span>
            }
        </div>
        @if (_legacyOnline != null)
        {
            <div class="px-3 py-2 small text-muted border-bottom players-legacy-stats">
                Online: @_legacyOnline.TotalOnline · Phòng: @_legacyOnline.TotalRoom · Trong trận: @_legacyOnline.TotalConnectionInGame
            </div>
        }
        @if (_session != null && _onlineListSource == OnlineListSource.Legacy && !string.IsNullOrEmpty(_errOnline))
        {
            <div class="alert alert-warning py-2 small mb-0 rounded-0 border-0 border-bottom">Không tải được danh sách chi tiết; đang hiển thị danh sách công khai.</div>
        }
        @if (_session != null && _onlineListSource == OnlineListSource.Legacy && string.IsNullOrEmpty(_errOnline) && _onlineStats?.Players?.Count == 0 && _legacyOnline?.Players?.Count > 0)
        {
            <div class="alert alert-secondary py-2 small mb-0 rounded-0 border-0 border-bottom">Danh sách chi tiết đang trống; hiển thị thêm danh sách công khai.</div>
        }
        <div class="card-body p-0">
            @if (_onlineDisplayRows.Count > 0)
            {
                <div class="table-responsive small">
                    <table class="table table-hover mb-0 players-table">
                        <thead class="table-light"><tr><th>Người chơi</th><th>Điểm</th><th>Trận</th><th class="text-end">Hành động</th></tr></thead>
                        <tbody>
                        @foreach (var p in _onlineDisplayRows)
                        {
                            var self = IsSelf(p.Id);
                            <tr>
                                <td>@p.Username</td>
                                <td>@p.Points</td>
                                <td>@p.Games</td>
                                <td class="text-end">
                                    @if (_session != null)
                                    {
                                        <button class="btn btn-sm btn-outline-primary px-3" type="button" disabled="@(self || _busyInviteId != null)" @onclick="() => InviteAsync(p.Id, p.Username)">
                                            @if (_busyInviteId == p.Id) { <span class="spinner-border spinner-border-sm" aria-hidden="true"></span> }
                                            else { <span>Mời</span> }
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Đăng nhập để mời</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else if (!string.IsNullOrEmpty(_errOnline) && _session != null && _onlineListSource == OnlineListSource.None)
            {
                <p class="text-danger small p-3 mb-0">@_errOnline</p>
            }
            else if (!string.IsNullOrEmpty(_errLegacy))
            {
                <p class="text-danger small p-3 mb-0">@_errLegacy</p>
            }
            else
            {
                <p class="text-muted small p-3 mb-0">Chưa có ai online.</p>
            }
        </div>
    </div>

    @if (_session != null)
    {
        <div class="card border-0 shadow-sm mt-4 players-card">
            <div class="card-header bg-transparent py-3 d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-envelope-open me-1" aria-hidden="true"></i>Lời mời đến</strong>
                @if (!string.IsNullOrEmpty(_invErr))
                {
                    <span class="text-danger small">@_invErr</span>
                }
            </div>
            <div class="card-body">
                @if (_invitations.Count == 0)
                {
                    <p class="text-muted small mb-0">Không có lời mời đang chờ.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush players-inv-list">
                        @foreach (var inv in _invitations)
                        {
                            <li class="list-group-item px-0 py-3 d-flex flex-column flex-md-row gap-3 justify-content-between align-items-md-center">
                                <div>
                                    <div class="fw-semibold">@inv.FromUsername</div>
                                    <div class="small text-muted">@inv.Message</div>
                                    <div class="small text-muted">@inv.CreatedAt.ToLocalTime().ToString("g")</div>
                                </div>
                                <div class="btn-group flex-shrink-0">
                                    <button class="btn btn-sm btn-success" type="button" disabled="@(_busyInviteAction != null)" @onclick="() => AcceptInviteAsync(inv.Id)">
                                        @if (_busyInviteAction == inv.Id + "a") { <span class="spinner-border spinner-border-sm"></span> }
                                        else { <span>Đồng ý</span> }
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled="@(_busyInviteAction != null)" @onclick="() => DeclineInviteAsync(inv.Id)">
                                        @if (_busyInviteAction == inv.Id + "d") { <span class="spinner-border spinner-border-sm"></span> }
                                        else { <span>Từ chối</span> }
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
}
</div>

<style>
    .players-hub-page .players-hero-subtitle {
        color: var(--bs-secondary-color);
        margin: .25rem 0 0;
    }

    .players-status-row {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .players-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .35rem .65rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, .08);
        color: var(--bs-body-color);
        font-size: .82rem;
    }

    .players-tabs .nav-link {
        border-radius: .7rem;
        padding: .5rem .9rem;
    }

    .players-tabs .nav-link.active {
        box-shadow: 0 6px 18px rgba(13, 110, 253, .25);
    }

    .players-card {
        border-radius: .9rem;
        overflow: hidden;
    }

    .players-table th,
    .players-table td {
        vertical-align: middle;
    }

    .players-table th {
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .03em;
        color: var(--bs-secondary-color);
    }

    .players-legacy-stats {
        background: rgba(255, 255, 255, .03);
    }

    .players-inv-list .list-group-item {
        border-color: rgba(255, 255, 255, .08);
    }
</style>

@code {
    private int _tab;
    private PortalAuthState? _session;
    private OnlinePlayersResponse? _onlineStats;
    private OnlinePlayerDetailDto? _legacyOnline;
    private string? _errOnline;
    private string? _errLegacy;
    private string? _invErr;
    private List<PlayerInvitationDto> _invitations = new();
    private bool _loadingOnline;
    private string? _busyInviteId;
    private string? _busyInviteAction;
    private string? _toastOk;
    private string? _toastErr;

    private string _searchQ = "";
    private OnlinePlayersResponse? _searchStats;
    private string _playerGuid = "";
    private DetailedPlayerStatsDto? _detail;
    private string? _errDetail;

    private enum OnlineListSource { None, PlayerStats, Legacy }

    private sealed record OnlineDisplayRow(string Id, string Username, long Points, int Games, OnlineListSource Source);

    private List<OnlineDisplayRow> _onlineDisplayRows = new();
    private OnlineListSource _onlineListSource;
    private CancellationTokenSource? _autoRefreshCts;
    private bool _autoRefreshEnabled = true;

    private static readonly TimeSpan AutoRefreshInterval = TimeSpan.FromSeconds(5);

    private void RebuildOnlineDisplayRows()
    {
        _onlineDisplayRows.Clear();
        _onlineListSource = OnlineListSource.None;

        if (_session != null)
        {
            var statsPlayers = _onlineStats?.Players;
            var statsOk = string.IsNullOrEmpty(_errOnline);
            if (statsOk && statsPlayers is { Count: > 0 })
            {
                foreach (var p in statsPlayers)
                    _onlineDisplayRows.Add(new OnlineDisplayRow(p.Id, p.Username, p.Points, p.GamesPlayed, OnlineListSource.PlayerStats));
                _onlineListSource = OnlineListSource.PlayerStats;
                return;
            }

            if (_legacyOnline?.Players is { Count: > 0 } leg)
            {
                foreach (var p in leg)
                    _onlineDisplayRows.Add(new OnlineDisplayRow(p.UserId, p.UserName, p.Point, p.GamePlayed, OnlineListSource.Legacy));
                _onlineListSource = OnlineListSource.Legacy;
                return;
            }

            return;
        }

        if (_legacyOnline?.Players is { Count: > 0 } guest)
        {
            foreach (var p in guest)
                _onlineDisplayRows.Add(new OnlineDisplayRow(p.UserId, p.UserName, p.Point, p.GamePlayed, OnlineListSource.Legacy));
            _onlineListSource = OnlineListSource.Legacy;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        ClearToasts();
        await RefreshOnlineAsync();
        StartAutoRefreshLoop();
        StateHasChanged();
    }

    private async Task OnTabAsync(int tab)
    {
        _tab = tab;
        if (tab == 0)
            await RefreshOnlineAsync();
    }

    private void ToggleAutoRefresh()
    {
        _autoRefreshEnabled = !_autoRefreshEnabled;
        if (_autoRefreshEnabled)
            _toastOk = "Đã bật tự động đồng bộ.";
        else
            _toastOk = "Đã tắt tự động đồng bộ.";
    }

    private string TabClass(int i) => "active"; // chỉ còn một tab online & lời mời

    private bool IsSelf(string playerId) =>
        _session != null && string.Equals(playerId, _session.UserId.ToString(), StringComparison.OrdinalIgnoreCase);

    private void ClearToasts()
    {
        _toastOk = _toastErr = null;
    }

    private async Task RefreshOnlineAsync() => await RefreshOnlineCoreAsync(clearToasts: true, showLoading: true);

    private async Task RefreshOnlineSilentAsync() => await RefreshOnlineCoreAsync(clearToasts: false, showLoading: false);

    private async Task RefreshOnlineCoreAsync(bool clearToasts, bool showLoading)
    {
        if (clearToasts)
            ClearToasts();
        if (showLoading)
        {
            _loadingOnline = true;
            StateHasChanged();
        }
        try
        {
            if (_session != null)
            {
                var t1 = Api.PlayersLegacyOnlineDetailAsync();
                var t2 = Api.GetOnlinePlayersStatsAsync();
                var t3 = Api.GetMyInvitationsAsync();
                await Task.WhenAll(t1, t2, t3);

                var (okL, legacy, errL) = await t1;
                _legacyOnline = legacy;
                _errLegacy = okL ? null : errL;

                var (okS, data, errS) = await t2;
                _onlineStats = data;
                _errOnline = okS ? null : errS;

                var (okI, list, errI) = await t3;
                _invitations = okI && list != null ? list.ToList() : new List<PlayerInvitationDto>();
                _invErr = okI ? null : errI;
            }
            else
            {
                var (okL, legacy, errL) = await Api.PlayersLegacyOnlineDetailAsync();
                _legacyOnline = legacy;
                _errLegacy = okL ? null : errL;
                _onlineStats = null;
                _errOnline = null;
                _invitations = new List<PlayerInvitationDto>();
                _invErr = null;
            }

            RebuildOnlineDisplayRows();
        }
        finally
        {
            if (showLoading)
                _loadingOnline = false;
        }
    }

    private void StartAutoRefreshLoop()
    {
        _autoRefreshCts?.Cancel();
        _autoRefreshCts?.Dispose();
        _autoRefreshCts = new CancellationTokenSource();
        var token = _autoRefreshCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(AutoRefreshInterval, token);

                    if (token.IsCancellationRequested || !_autoRefreshEnabled || _tab != 0)
                        continue;
                    if (_loadingOnline || _busyInviteId != null || _busyInviteAction != null)
                        continue;

                    await InvokeAsync(async () =>
                    {
                        await RefreshOnlineSilentAsync();
                        StateHasChanged();
                    });
                }
            }
            catch (TaskCanceledException)
            {
                // ignored: normal when component disposed
            }
            catch (ObjectDisposedException)
            {
                // ignored: normal when component disposed
            }
        }, token);
    }

    /// <summary>Chỉ tải lại danh sách lời mời (không xóa toast thành công từ đồng ý/từ chối).</summary>
    private async Task LoadInvitationsOnlyAsync()
    {
        if (_session == null) return;
        var (ok, list, err) = await Api.GetMyInvitationsAsync();
        _invitations = ok && list != null ? list.ToList() : new List<PlayerInvitationDto>();
        _invErr = ok ? null : err;
    }

    private async Task RefreshInvitationsButtonAsync()
    {
        ClearToasts();
        await LoadInvitationsOnlyAsync();
        if (string.IsNullOrEmpty(_invErr))
            _toastOk = "Đã cập nhật lời mời.";
    }

    private async Task InviteAsync(string playerId, string? displayName)
    {
        ClearToasts();
        _busyInviteId = playerId;
        try
        {
            var (ok, _, err) = await Api.PlayersInviteAsync(playerId, $"Lời mời từ trang Người chơi{(string.IsNullOrEmpty(displayName) ? "" : $" → {displayName}")}");
            if (ok)
            {
                _toastOk = "Đã gửi lời mời.";
                await RefreshOnlineSilentAsync();
            }
            else
                _toastErr = err ?? "Gửi lời mời thất bại.";
        }
        finally
        {
            _busyInviteId = null;
        }
    }

    private async Task AcceptInviteAsync(string inviteId)
    {
        ClearToasts();
        _busyInviteAction = inviteId + "a";
        try
        {
            var (ok, _, roomId, msg, err) = await Api.AcceptInvitationAsync(inviteId);
            if (ok)
            {
                _toastOk = msg ?? "Bạn đã đồng ý.";
                await LoadInvitationsOnlyAsync();
                await RefreshOnlineSilentAsync();
                if (!string.IsNullOrEmpty(roomId))
                {
                    // Điều hướng cả người nhận vào phòng mới để thi đấu
                    NavigationManager.NavigateTo($"/play/{roomId}");
                }
            }
            else
                _toastErr = err ?? "Không chấp nhận được lời mời.";
        }
        finally
        {
            _busyInviteAction = null;
        }
    }

    private async Task DeclineInviteAsync(string inviteId)
    {
        ClearToasts();
        _busyInviteAction = inviteId + "d";
        try
        {
            var (ok, msg, err) = await Api.DeclineInvitationAsync(inviteId);
            if (ok)
            {
                _toastOk = msg ?? "Đã từ chối.";
                await LoadInvitationsOnlyAsync();
                await RefreshOnlineSilentAsync();
            }
            else
                _toastErr = err ?? "Không từ chối được.";
        }
        finally
        {
            _busyInviteAction = null;
        }
    }

    private async Task SearchStatsAsync()
    {
        ClearToasts();
        if (_session == null)
        {
            _toastErr = "Đăng nhập để tìm người chơi.";
            return;
        }
        var (ok, data, err) = await Api.SearchPlayersStatsAsync(_searchQ);
        _searchStats = data;
        if (!ok)
            _toastErr = err ?? "Tìm kiếm thất bại.";
    }

    private async Task LoadDetailStatsAsync()
    {
        ClearToasts();
        _errDetail = null;
        _detail = null;
        if (_session == null)
        {
            _toastErr = "Đăng nhập để xem chi tiết người chơi.";
            return;
        }
        if (!Guid.TryParse(_playerGuid, out var g))
        {
            _errDetail = "GUID không hợp lệ";
            _toastErr = _errDetail;
            return;
        }
        var (ok, d, err) = await Api.GetDetailedPlayerStatsAsync(g);
        _detail = d;
        if (!ok)
        {
            _errDetail = err;
            _toastErr = err ?? "Không tải được chi tiết.";
        }
    }

    public ValueTask DisposeAsync()
    {
        _autoRefreshCts?.Cancel();
        _autoRefreshCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
