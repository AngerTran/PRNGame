@page "/me/points"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth

<PageTitle>Điểm</PageTitle>

<div class="rps-community-shell">
    <header class="rps-community-hero">
        <p class="rps-community-kicker"><i class="bi bi-wallet2" aria-hidden="true"></i> Cộng đồng</p>
        <h1 class="rps-community-title">Điểm (Points API)</h1>
    </header>
    <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
        <a class="rps-hub-pill" href="/lobby"><i class="bi bi-door-open" aria-hidden="true"></i>Sảnh</a>
    </nav>

    @if (_session == null)
    {
        <p class="mb-0"><a href="/login">Đăng nhập</a></p>
    }
    else
    {
        <div class="card mb-3 rps-profile-highlight">
            <div class="card-body">
                <p class="rps-community-api-label mb-2">GET api/v1/points/current</p>
                <p class="mb-0 fs-4 fw-semibold">@_myPoints điểm</p>
                <button type="button" class="btn btn-sm btn-outline-primary mt-3" @onclick="RefreshMineAsync">Làm mới</button>
            </div>
        </div>

        <div class="card">
            <div class="card-header">GET api/v1/points/&#123;userId&#125;</div>
            <div class="card-body">
                <div class="input-group">
                    <input class="form-control" @bind="_otherId" placeholder="Guid" />
                    <button type="button" class="btn btn-primary" @onclick="LoadOtherAsync">Xem</button>
                </div>
                @if (_otherPoints.HasValue)
                {
                    <p class="mt-3 mb-0">Điểm: <strong>@_otherPoints</strong></p>
                }
                @if (!string.IsNullOrEmpty(_otherErr))
                {
                    <p class="text-danger small mt-2 mb-0">@_otherErr</p>
                }
            </div>
        </div>
    }
</div>

@code {
    private PortalAuthState? _session;
    private long _myPoints;
    private string _otherId = "";
    private long? _otherPoints;
    private string? _otherErr;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _session = await Auth.LoadAsync();
        if (_session != null)
            await RefreshMineAsync();
        StateHasChanged();
    }

    private async Task RefreshMineAsync()
    {
        var (ok, pts, _) = await Api.GetCurrentPointsAsync();
        if (ok) _myPoints = pts;
    }

    private async Task LoadOtherAsync()
    {
        _otherErr = null;
        _otherPoints = null;
        if (!Guid.TryParse(_otherId, out var g))
        {
            _otherErr = "GUID không hợp lệ";
            return;
        }
        var (ok, pts, err) = await Api.GetUserPointsAsync(g);
        if (!ok) _otherErr = err;
        else _otherPoints = pts;
    }
}
