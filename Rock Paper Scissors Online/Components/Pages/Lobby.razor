@page "/lobby"
@rendermode InteractiveServer
@inject GameApiService Api
@inject AuthTokenStore Auth
@inject NavigationManager Nav

<PageTitle>Sảnh game</PageTitle>

@if (!_ready)
{
    <div class="rps-lobby-skeleton" aria-busy="true" aria-label="Đang tải sảnh">
        <div class="rps-lobby-skeleton-line rps-lobby-skeleton-line--lg"></div>
        <div class="rps-lobby-skeleton-line rps-lobby-skeleton-line--md"></div>
        <div class="rps-lobby-skeleton-card"></div>
    </div>
}
else
{
    <div class="rps-lobby-shell">
        <div class="rps-lobby">
            <header class="rps-lobby-hero rps-lobby-hero--elevated">
                <div class="rps-lobby-hero-text">
                    <div class="rps-lobby-hero-icon-wrap" aria-hidden="true">
                        <i class="bi bi-controller"></i>
                    </div>
                    <div>
                        <p class="rps-lobby-kicker">Kéo · Búa · Bao</p>
                        <h1 class="rps-lobby-title">Sảnh phòng</h1>
                        <p class="rps-lobby-greet">
                            Xin chào, <span class="rps-lobby-username">@_session!.Username</span>
                        </p>
                    </div>
                </div>
                <button class="rps-lobby-refresh-btn" type="button" disabled="@_busy" @onclick="RefreshRoomsAsync"
                    title="Tải lại danh sách phòng">
                    <span class="rps-lobby-refresh-icon" aria-hidden="true">
                        <i class="bi bi-arrow-clockwise @( _busy ? "rps-lobby-spin" : "" )"></i>
                    </span>
                    <span class="rps-lobby-refresh-label">Làm mới</span>
                </button>
            </header>

            <nav class="rps-hub-quicklinks" aria-label="Liên kết nhanh">
                <a class="rps-hub-pill" href="/portal"><i class="bi bi-cpu" aria-hidden="true"></i>Trung tâm API</a>
                <a class="rps-hub-pill" href="/"><i class="bi bi-house" aria-hidden="true"></i>Trang Razor</a>
                <a class="rps-hub-pill" href="/history"><i class="bi bi-clock-history" aria-hidden="true"></i>Lịch sử trận</a>
                <a class="rps-hub-pill" href="/howtoplay"><i class="bi bi-book" aria-hidden="true"></i>Cách chơi</a>
            </nav>

            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="rps-lobby-toast @(_messageAlertClass) d-flex align-items-start gap-2" role="status">
                    <i class="bi rps-lobby-toast-ic @(AlertIconClass()) mt-1" aria-hidden="true"></i>
                    <div class="flex-grow-1 small rps-lobby-toast-body">@_message</div>
                    <button type="button" class="btn-close rps-lobby-toast-close" @onclick="DismissMessage"
                        aria-label="Đóng"></button>
                </div>
            }

            <section class="rps-lobby-panel rps-lobby-panel--create">
                <div class="rps-lobby-panel-head rps-lobby-panel-head--split">
                    <div class="d-flex align-items-center gap-2">
                        <span class="rps-lobby-panel-ic"><i class="bi bi-plus-lg" aria-hidden="true"></i></span>
                        <div>
                            <h2 class="rps-lobby-panel-title">Tham gia phòng chơi</h2>
                            <p class="rps-lobby-panel-sub mb-0">Đấu 1 vs 1 · tối đa 2 người chơi</p>
                        </div>
                    </div>
                    <div class="rps-lobby-panel-points">
                        <p class="rps-lobby-panel-points-label mb-1">Điểm hiện tại</p>
                        @if (_pointsLoading)
                        {
                            <p class="rps-lobby-panel-points-value rps-lobby-panel-points-value--muted mb-0">…</p>
                        }
                        else if (_pointsLoadFailed)
                        {
                            <p class="rps-lobby-panel-points-value rps-lobby-panel-points-value--muted mb-0">—</p>
                            <p class="rps-lobby-panel-points-sub mb-0">Không tải được</p>
                        }
                        else
                        {
                            <p class="rps-lobby-panel-points-value mb-0">@_myPoints.ToString("N0")</p>
                            <a class="rps-lobby-panel-points-link" href="/me/points">Chi tiết điểm</a>
                        }
                    </div>
                </div>
                <div class="rps-lobby-panel-body">
                    <div class="row g-3 g-lg-4 align-items-end">
                        <div class="col-lg-4 col-md-6">
                            <label class="rps-lobby-label" for="lobby-room-name">Tên phòng</label>
                            <div class="rps-lobby-input-wrap">
                                <i class="bi bi-door-open rps-lobby-input-ic" aria-hidden="true"></i>
                                <input id="lobby-room-name" class="form-control rps-lobby-input" @bind="_createName"
                                    maxlength="50" autocomplete="off" placeholder="VD: Phòng VIP" />
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-3 col-6">
                            <label class="rps-lobby-label" for="lobby-bestof"
                                title="Số hiệp tối đa; ai thắng trước đa số hiệp thì thắng cả trận.">Số hiệp tối đa</label>
                            <input id="lobby-bestof" type="number" class="form-control rps-lobby-input"
                                @bind="_createBestOf" min="1" max="15" />
                        </div>
                        <div class="col-lg-2 col-md-3 col-6">
                            <label class="rps-lobby-label" for="lobby-points">Điểm / ván thắng</label>
                            <div class="rps-lobby-input-wrap">
                                <i class="bi bi-trophy rps-lobby-input-ic" aria-hidden="true"></i>
                                <input id="lobby-points" type="number" class="form-control rps-lobby-input"
                                    @bind="_createPoints" min="10" max="1000" />
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-12">
                            <div class="rps-lobby-create-actions">
                                <label class="rps-lobby-check">
                                    <input type="checkbox" class="form-check-input" id="lobby-priv"
                                        @bind="_createPrivate" />
                                    <span>Phòng riêng <span class="rps-lobby-check-hint">(PIN)</span></span>
                                </label>
                                @if (_createPrivate)
                                {
                                    <p class="rps-lobby-pin-create-hint mb-0">
                                        Hệ thống tự tạo mã PIN 6 ký tự. <strong class="text-light">Chỉ chủ phòng</strong> thấy mã
                                        trên màn chơi và trong danh sách. Người vào sau nhập PIN trong hộp thoại khi bấm
                                        <strong class="text-light">Vào phòng</strong>.
                                    </p>
                                }
                                <button class="btn rps-lobby-create-btn" type="button" disabled="@_busy"
                                    @onclick="CreateAsync">
                                    <i class="bi bi-lightning-charge-fill me-1" aria-hidden="true"></i>Tạo phòng
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rps-lobby-panel rps-lobby-panel--list">
                <div class="rps-lobby-list-toolbar">
                    <h2 class="rps-lobby-list-title">
                        <i class="bi bi-list-ul me-2" aria-hidden="true"></i>Danh sách phòng
                    </h2>
                    @if (_rooms.Count > 0)
                    {
                        <span class="rps-lobby-count">@_rooms.Count phòng</span>
                    }
                </div>
                <div class="rps-lobby-table-responsive">
                    <table class="table table-sm align-middle mb-0 rps-lobby-table">
                        <thead>
                            <tr>
                                <th scope="col">Tên</th>
                                <th scope="col">Người chơi</th>
                                <th scope="col">Trạng thái</th>
                                <th scope="col">Riêng tư</th>
                                <th scope="col" class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_rooms.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="rps-lobby-empty">
                                        <div class="rps-lobby-empty-inner">
                                            <div class="rps-lobby-empty-visual" aria-hidden="true">
                                                <i class="bi bi-door-open rps-lobby-empty-ic"></i>
                                            </div>
                                            <p class="rps-lobby-empty-title">Chưa có phòng nào</p>
                                            <p class="rps-lobby-empty-sub">Tạo phòng mới hoặc bấm <strong
                                                    class="rps-lobby-empty-strong">Làm mới</strong> để tải danh sách.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var r in _rooms)
                                {
                                    var inRoom = IsCurrentUserInRoom(r);
                                    <tr class="rps-lobby-row">
                                        <td>
                                            <span class="rps-lobby-room-name">@r.Name</span>
                                        </td>
                                        <td>
                                            <span class="rps-lobby-players">
                                                <i class="bi bi-people-fill rps-lobby-players-ic" aria-hidden="true"></i>
                                                @r.CurrentPlayers / @r.MaxPlayers
                                            </span>
                                        </td>
                                        <td>
                                            <span
                                                class="rps-lobby-badge @StatusBadgeClass(r.Status)">@FormatRoomStatus(r.Status)</span>
                                        </td>
                                        <td>
                                            @if (r.IsPrivate)
                                            {
                                                <span class="rps-lobby-privacy rps-lobby-privacy--yes"><i class="bi bi-lock-fill me-1"
                                                        aria-hidden="true"></i>Có</span>
                                            }
                                            else
                                            {
                                                <span class="rps-lobby-privacy rps-lobby-privacy--no">Không</span>
                                            }
                                        </td>
                                        <td class="text-end text-nowrap rps-lobby-actions">
                                            @if (r.IsPrivate && IsRoomHost(r) && !string.IsNullOrEmpty(r.PinCode))
                                            {
                                                <span class="rps-lobby-pin-badge me-1" title="Chỉ chủ phòng thấy mã này">
                                                    PIN <code>@r.PinCode</code>
                                                </span>
                                            }
                                            @if (inRoom)
                                            {
                                                <button class="btn btn-sm rps-lobby-btn-secondary" type="button" disabled="@_busy"
                                                    @onclick="() => OnEnterRoomClickAsync(r)">
                                                    <i class="bi bi-box-arrow-in-right me-1" aria-hidden="true"></i>Vào lại
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm rps-lobby-btn-join" type="button" disabled="@_busy"
                                                    @onclick="() => OnEnterRoomClickAsync(r)">
                                                    <i class="bi bi-play-fill me-1" aria-hidden="true"></i>Vào phòng
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="rps-lobby-panel rps-lobby-panel--betting" id="betting-rooms">
                <div class="rps-lobby-list-toolbar">
                    <h2 class="rps-lobby-list-title">
                        <i class="bi bi-coin me-2" aria-hidden="true"></i>Trận đang đấu — xem &amp; cược
                    </h2>
                </div>
                <p class="rps-lobby-betting-hint">Chỉ phòng bật cược và đang có 2 người chơi. Phòng PIN: cần mã khi đặt cược.</p>
                @if (BettingRooms.Count == 0)
                {
                    <p class="rps-lobby-betting-empty"><i class="bi bi-eye-slash me-1" aria-hidden="true"></i>Hiện không có phòng phù hợp.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0 rps-lobby-betting-list">
                        @foreach (var r in BettingRooms)
                        {
                            <li class="rps-lobby-betting-item">
                                <span class="rps-lobby-betting-name"><i class="bi bi-broadcast me-2 text-info" aria-hidden="true"></i>@r.Name</span>
                                <a class="btn btn-sm rps-lobby-btn-join" href="@WatchHref(r)">Xem / cược</a>
                            </li>
                        }
                    </ul>
                }
            </section>
        </div>

        @if (_ready)
        {
            <RpsDualChatPanel />
        }
    </div>

    @if (_pinModalRoom != null)
    {
        <div class="rps-lobby-modal-backdrop" @onclick="ClosePinModal" aria-hidden="true"></div>
        <div class="rps-lobby-modal" role="dialog" aria-modal="true" aria-labelledby="rps-pin-modal-title">
            <h3 id="rps-pin-modal-title" class="rps-lobby-modal-title">
                <i class="bi bi-shield-lock me-2" aria-hidden="true"></i>Phòng riêng
            </h3>
            <p class="rps-lobby-modal-text small mb-2">
                Phòng <strong>@_pinModalRoom.Name</strong> — nhập mã PIN do chủ phòng gửi.
            </p>
            <label class="rps-lobby-label" for="rps-pin-input">Mã PIN</label>
            <input id="rps-pin-input" class="form-control rps-lobby-modal-input mb-2" maxlength="8" autocomplete="off"
                placeholder="VD: ABC12X" @bind="_pinModalValue" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(_pinModalError))
            {
                <p class="small text-danger mb-2 mb-md-3">@_pinModalError</p>
            }
            <div class="rps-lobby-modal-actions">
                <button type="button" class="btn rps-lobby-btn-secondary" @onclick="ClosePinModal" disabled="@_busy">Hủy</button>
                <button type="button" class="btn rps-lobby-btn-join" @onclick="ConfirmPinModalAsync" disabled="@_busy">
                    @(_busy ? "Đang xử lý…" : "Vào phòng")
                </button>
            </div>
        </div>
    }
}

@code {
    private PortalAuthState? _session;
    private List<RoomResponseDto> _rooms = new();
    private readonly Dictionary<string, string> _pinByRoom = new();
    private bool _ready;
    private bool _busy;
    private string? _message;
    private string _messageAlertClass = "rps-lobby-toast--info";

    private string _createName = "Phòng mới";
    private int _createBestOf = 3;
    private int _createPoints = 50;
    private bool _createPrivate;
    private bool _roomsLoadedOnce;
    private long _myPoints;
    private bool _pointsLoading = true;
    private bool _pointsLoadFailed;
    private bool _pointsHydrated;

    private RoomResponseDto? _pinModalRoom;
    private PinModalIntent _pinModalIntent;
    private string _pinModalValue = "";
    private string? _pinModalError;

    private enum PinModalIntent
    {
        JoinRoom,
        ReturnToPlay
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var s = await Auth.LoadAsync();
        if (s == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        _session = s;
        await RefreshRoomsAsync();
        _ready = true;
        StateHasChanged();
    }

    private string AlertIconClass() => _messageAlertClass switch
    {
        "rps-lobby-toast--danger" => "bi-exclamation-octagon-fill",
        "rps-lobby-toast--warn" => "bi-exclamation-triangle-fill",
        _ => "bi-info-circle-fill"
    };

    private void DismissMessage()
    {
        _message = null;
    }

    private bool IsCurrentUserInRoom(RoomResponseDto r)
    {
        if (_session is null)
            return false;
        var uid = _session.UserId.ToString();
        return string.Equals(r.CreatedBy, uid, StringComparison.OrdinalIgnoreCase)
        || string.Equals(r.Player1?.UserId, uid, StringComparison.OrdinalIgnoreCase)
        || string.Equals(r.Player2?.UserId, uid, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsRoomHost(RoomResponseDto r)
    {
        if (_session is null)
            return false;
        return string.Equals(r.CreatedBy, _session.UserId.ToString(), StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatRoomStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
            return "—";

        var s = status.Trim();
        var lower = s.ToLowerInvariant();
        return lower switch
        {
            "waiting" => "Chờ người chơi",
            "playing" => "Đang đấu",
            "inprogress" => "Đang đấu",
            "completed" => "Đã kết thúc",
            "finished" => "Đã kết thúc",
            _ when lower.Contains("chờ") || lower.Contains("wait") => "Chờ người chơi",
            _ when lower.Contains("đấu") || lower.Contains("play") => "Đang đấu",
            _ when lower.Contains("kết") || lower.Contains("finish") || lower.Contains("complete") => "Đã kết thúc",
            _ => s
        };
    }

    private static string StatusBadgeClass(string? status)
    {
        var lower = status?.Trim().ToLowerInvariant() ?? "";
        if (lower.Contains("chờ") || lower.Contains("wait")) return "rps-lobby-badge--wait";
        if (lower.Contains("đấu") || lower == "playing" || lower == "inprogress") return "rps-lobby-badge--play";
        if (lower.Contains("kết") || lower == "completed" || lower == "finished") return "rps-lobby-badge--done";
        return lower switch
        {
            "waiting" => "rps-lobby-badge--wait",
            "playing" or "inprogress" => "rps-lobby-badge--play",
            "completed" or "finished" => "rps-lobby-badge--done",
            _ => "rps-lobby-badge--muted"
        };
    }

    private IReadOnlyList<RoomResponseDto> BettingRooms =>
        _rooms.Where(CanWatchBet).OrderBy(r => r.Name).ToList();

    private static bool CanWatchBet(RoomResponseDto r)
    {
        if (!r.AllowBetting || r.CurrentPlayers < 2 || r.Player1 == null || r.Player2 == null)
            return false;
        var st = r.Status?.Trim() ?? "";
        return st.Equals("Playing", StringComparison.OrdinalIgnoreCase)
               || st.Equals("InProgress", StringComparison.OrdinalIgnoreCase);
    }

    private static string WatchHref(RoomResponseDto r) =>
        $"/watch/{Uri.EscapeDataString(r.Id)}";

    private async Task RefreshRoomsAsync()
    {
        _message = null;
        if (_roomsLoadedOnce)
            _busy = true;
        try
        {
            var (ok, list, err) = await Api.GetRoomsAsync();
            if (!ok)
            {
                _messageAlertClass = "rps-lobby-toast--danger";
                _message = err ?? "Không tải được danh sách phòng";
                return;
            }

            _rooms = list;
            foreach (var r in _rooms)
            {
                if (!_pinByRoom.ContainsKey(r.Id))
                    _pinByRoom[r.Id] = "";
                if (r.IsPrivate && IsRoomHost(r) && !string.IsNullOrEmpty(r.PinCode))
                    _pinByRoom[r.Id] = r.PinCode;
            }
        }
        finally
        {
            _busy = false;
            _roomsLoadedOnce = true;
            await LoadMyPointsAsync();
        }
    }

    private async Task LoadMyPointsAsync()
    {
        if (!_pointsHydrated)
        {
            _pointsLoading = true;
            await InvokeAsync(StateHasChanged);
        }

        _pointsLoadFailed = false;
        var (ok, pts, _) = await Api.GetCurrentPointsAsync();
        if (ok)
        {
            _myPoints = pts;
            _pointsLoadFailed = false;
        }
        else
        {
            _pointsLoadFailed = true;
        }

        _pointsHydrated = true;
        _pointsLoading = false;
    }

    private void OpenPinModal(RoomResponseDto room, PinModalIntent intent)
    {
        _pinModalRoom = room;
        _pinModalIntent = intent;
        _pinModalValue = _pinByRoom.TryGetValue(room.Id, out var p) ? p : "";
        _pinModalError = null;
    }

    private void ClosePinModal()
    {
        _pinModalRoom = null;
        _pinModalValue = "";
        _pinModalError = null;
    }

    private static string NormalizePin(string? s)
    {
        if (string.IsNullOrWhiteSpace(s))
            return "";
        return s.Trim().ToUpperInvariant();
    }

    private async Task ConfirmPinModalAsync()
    {
        if (_pinModalRoom == null)
            return;

        _pinModalError = null;
        var pin = NormalizePin(_pinModalValue);
        if (string.IsNullOrEmpty(pin))
        {
            _pinModalError = "Nhập mã PIN.";
            return;
        }

        _pinByRoom[_pinModalRoom.Id] = pin;
        var room = _pinModalRoom;
        var intent = _pinModalIntent;
        ClosePinModal();

        if (intent == PinModalIntent.JoinRoom)
            await TryJoinAndNavigateAsync(room, pin);
        else
            Nav.NavigateTo($"/play/{room.Id}?pin={Uri.EscapeDataString(pin)}");
    }

    private async Task OnEnterRoomClickAsync(RoomResponseDto r)
    {
        if (IsCurrentUserInRoom(r))
            await GoToPlayAsync(r);
        else if (!r.IsPrivate)
            await TryJoinAndNavigateAsync(r, null);
        else
            OpenPinModal(r, PinModalIntent.JoinRoom);
    }

    private async Task GoToPlayAsync(RoomResponseDto r)
    {
        _busy = true;
        try
        {
            string? pin = null;
            if (r.IsPrivate)
            {
                if (IsRoomHost(r))
                {
                    var (ok, room, _) = await Api.GetRoomAsync(r.Id);
                    pin = ok ? room?.PinCode : null;
                }
                else
                {
                    pin = _pinByRoom.TryGetValue(r.Id, out var p) ? p : null;
                    if (string.IsNullOrWhiteSpace(pin))
                    {
                        OpenPinModal(r, PinModalIntent.ReturnToPlay);
                        return;
                    }
                }
            }

            var q = string.IsNullOrWhiteSpace(pin) ? "" : $"?pin={Uri.EscapeDataString(pin)}";
            Nav.NavigateTo($"/play/{r.Id}{q}");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task TryJoinAndNavigateAsync(RoomResponseDto r, string? pin)
    {
        _busy = true;
        _message = null;
        try
        {
            var (ok, room, err) = await Api.JoinRoomAsync(r.Id, r.IsPrivate ? pin : null);
            if (!ok || room == null)
            {
                _messageAlertClass = "rps-lobby-toast--danger";
                _message = err ?? "Không vào được phòng";
                return;
            }

            if (r.IsPrivate && !string.IsNullOrWhiteSpace(pin))
                _pinByRoom[r.Id] = pin!;

            var q = r.IsPrivate && !string.IsNullOrWhiteSpace(pin) ? $"?pin={Uri.EscapeDataString(pin!)}" : "";
            Nav.NavigateTo($"/play/{room.Id}{q}");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_createName) || _createName.Length < 3)
        {
            _messageAlertClass = "rps-lobby-toast--warn";
            _message = "Tên phòng ít nhất 3 ký tự.";
            return;
        }

        _busy = true;
        try
        {
            var dto = new CreateRoomDto
            {
                Name = _createName.Trim(),
                BestOfRounds = _createBestOf,
                PointsPerWin = _createPoints,
                MaxPlayers = 2,
                IsPrivate = _createPrivate,
                AllowSpectators = true,
                AllowBetting = true
            };
            var (ok, room, err) = await Api.CreateRoomAsync(dto);
            if (!ok || room == null)
            {
                _messageAlertClass = "rps-lobby-toast--danger";
                _message = err ?? "Tạo phòng thất bại";
                return;
            }

            if (room.IsPrivate && !string.IsNullOrEmpty(room.PinCode))
                _pinByRoom[room.Id] = room.PinCode;

            var q = room.IsPrivate && !string.IsNullOrEmpty(room.PinCode)
                ? $"?pin={Uri.EscapeDataString(room.PinCode)}"
                : "";
            Nav.NavigateTo($"/play/{room.Id}{q}", forceLoad: false);
        }
        finally
        {
            _busy = false;
        }
    }
}
