<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kéo Búa Bao Online</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/app.css" />
</head>
<body class="rps-razor">
    <header class="rps-razor-header mb-0">
        <div class="rps-razor-header-inner">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <a href="/" class="text-decoration-none d-flex align-items-center gap-2">
                    <span class="fs-4" aria-hidden="true">🎮</span>
                    <strong class="rps-brand-mark fs-5 mb-0">Kéo Búa Bao Online</strong>
                </a>
                <nav class="rps-razor-nav d-flex flex-wrap align-items-center gap-2 gap-md-3">
                    <a class="nav-link-style text-decoration-none" asp-page="/Index"><i class="bi bi-house-door-fill me-1"></i>Trang chủ</a>
                    <a class="nav-link-style text-decoration-none" href="/lobby"><i class="bi bi-controller me-1"></i>Sảnh</a>
                    <a class="nav-link-style text-decoration-none" href="/register"><i class="bi bi-person-plus me-1"></i>Đăng ký</a>
                    <a class="btn btn-sm btn-primary" href="/login"><i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập</a>
                </nav>
            </div>
        </div>
    </header>
    <main class="rps-razor-main-shell">
        <div class="rps-razor-card">
            @RenderBody()
        </div>
    </main>
    <footer class="rps-razor-footer small py-3 mt-auto">
        <div class="rps-razor-footer-inner d-flex flex-wrap align-items-center gap-2 justify-content-between">
            <span><i class="bi bi-cpu me-1"></i>ASP.NET Core · Razor + Blazor · SignalR</span>
            <a class="text-decoration-none rps-razor-footer-link" href="/lobby">Sảnh chơi →</a>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
